---
interface Props {
  title: string;
  subtitle: string;
  primaryText: string;
  primaryHref: string;
  secondaryText?: string;
  secondaryHref?: string;
  variant?: 'light' | 'dark';
}
const { title, subtitle, primaryText, primaryHref, secondaryText, secondaryHref, variant = 'light' } = Astro.props;
---

<section class:list={['cta-band', `cta-${variant}`]}>
  <div class="mw cta-inner">
    <div>
      <h2>{title}</h2>
      <p>{subtitle}</p>
    </div>
    <div class="cta-btns">
      <a href={primaryHref} class:list={['btn-primary', { 'btn-dark': variant === 'light', 'btn-light': variant === 'dark' }]}>{primaryText}</a>
      {secondaryText && secondaryHref && (
        <a href={secondaryHref} class="btn-outline">{secondaryText}</a>
      )}
    </div>
  </div>
</section>

<style>
  .cta-band { padding: 80px 0; }
  .cta-light { border-top: 1px solid var(--border); }
  .cta-dark { background: var(--dark); }
  .cta-inner { display: flex; justify-content: space-between; align-items: center; }
  .cta-inner h2 { font-size: 32px; font-weight: 600; margin-bottom: 8px; }
  .cta-light h2 { color: var(--navy); }
  .cta-dark h2 { color: white; }
  .cta-inner p { font-size: 17px; max-width: 420px; }
  .cta-light p { color: var(--text-mid); }
  .cta-dark p { color: rgba(255,255,255,0.45); }
  .cta-btns { display: flex; gap: 16px; }
  .btn-primary { display: inline-block; }
  @media (max-width: 768px) {
    .cta-band { padding: 60px 0; }
    .cta-band .mw { padding: 0 24px; }
    .cta-inner { flex-direction: column; gap: 24px; text-align: center; align-items: center; }
    .cta-inner h2 { font-size: 26px; }
    .cta-btns { flex-direction: column; width: 100%; }
    .cta-btns a { text-align: center; }
  }
</style>
