---
interface Props {
  items: { q: string; a: string }[];
  color?: string;
  title?: string;
}
const { items, color = 'navy', title = 'Questions' } = Astro.props;
---

<section class="faq-section">
  <div class="faq-inner">
    <div class="section-header">
      <div class="section-mark" style={`background: var(--${color})`}></div>
      <div><h2>{title}</h2></div>
    </div>
    {items.map((item, i) => (
      <div class:list={['faq-item', { last: i === items.length - 1 }]}>
        <div class="faq-q">{item.q}</div>
        <div class="faq-a" set:html={item.a} />
      </div>
    ))}
  </div>
</section>

<style>
  .faq-section { border-top: 1px solid var(--border); padding: 80px 0; }
  .faq-inner { max-width: 780px; margin: 0 auto; padding: 0 40px; }
  .faq-inner .section-header { margin-bottom: 48px; }
  .faq-item { border-top: 1px solid var(--border); padding: 28px 0; }
  .faq-item.last { border-bottom: 1px solid var(--border); }
  .faq-q { font-size: 18px; font-weight: 600; color: var(--navy); margin-bottom: 10px; }
  .faq-a { font-size: 16px; line-height: 1.6; color: var(--text-mid); max-width: 600px; }
  @media (max-width: 768px) {
    .faq-inner { padding: 0 24px; }
    .faq-q { font-size: 16px; }
    .faq-section { padding: 60px 0; }
  }
</style>
