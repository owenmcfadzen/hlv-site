---
import ArrowSquare from './ArrowSquare.astro';

interface Props {
  eyebrow?: string;
  lineOne?: string;
  lineTwo?: string;      // accent line (gets the violet highlight block)
  lineThree?: string;
  subtext?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  videoSrc?: string;
  posterSrc?: string;
}
const {
  eyebrow = 'Summer 2026 · Four cities · Applications open',
  lineOne = 'The summer that',
  lineTwo = 'makes school',
  lineThree = 'make sense.',
  subtext = 'Hudson Lab is a two-week program where high-school students work on a real business problem, with real operators, in New York, Lisbon, Porto, or Seoul.',
  primaryLabel = 'Apply now',
  primaryHref = '/admissions',
  secondaryLabel = 'See the program',
  secondaryHref = '/programs',
  videoSrc,
  posterSrc,
} = Astro.props;
---

<section class="hero-video">
  <div class="hv-media">
    {videoSrc ? (
      <video autoplay muted loop playsinline poster={posterSrc}>
        <source src={videoSrc} type="video/mp4" />
      </video>
    ) : (
      <div class="hv-placeholder" aria-label="Hero video placeholder">
        <span>Hero video placeholder · drop hero.mp4 in /public and pass videoSrc="/hero.mp4"</span>
      </div>
    )}
    <div class="hv-scrim" aria-hidden="true"></div>
  </div>

  <!-- Overlay: white card, bottom-left, hangs 1/3 below video into the next (dark) section -->
  <div class="hv-overlay">
    <div class="hv-eyebrow"><span class="dot"></span> {eyebrow}</div>
    <h1 class="hv-headline">
      <span class="hv-line">{lineOne}</span>
      <span class="hv-line hv-line-accent">{lineTwo}</span>
      <span class="hv-line">{lineThree}</span>
    </h1>
    <p class="hv-sub">{subtext}</p>
    <div class="hv-cta-row">
      <a class="btn-dark hv-cta" href={primaryHref}>{primaryLabel} <ArrowSquare size="small" /></a>
      <a class="hv-link" href={secondaryHref}>{secondaryLabel} →</a>
    </div>
  </div>
</section>

<style>
  .hero-video {
    position: relative;
    width: 100%;
    background: var(--dark);
    padding-top: 56px; /* fixed nav */
    overflow: visible; /* overlay must bleed below */
  }
  .hv-media { position: relative; width: 100%; height: 86vh; overflow: hidden; }
  .hv-media video { width: 100%; height: 100%; object-fit: cover; display: block; }
  .hv-placeholder {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, #131317 0%, #1f1f24 45%, #2a2a31 100%);
    display: flex; align-items: flex-end; justify-content: flex-end;
    padding: 40px;
  }
  .hv-placeholder span {
    font-family: 'Barlow Semi Condensed', sans-serif;
    font-size: 11px; font-weight: 500; letter-spacing: 0.08em;
    text-transform: uppercase; color: rgba(255,255,255,0.22);
  }
  .hv-scrim {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(0,0,0,0.55) 100%);
    pointer-events: none;
  }

  /* Overlay — white card, off-center left, hangs 1/3 below video into next dark section */
  .hv-overlay {
    position: absolute;
    left: 80px;
    bottom: 0;
    transform: translateY(33%);
    width: min(620px, calc(100vw - 160px));
    z-index: 3;
    background: var(--warm-white);
    padding: 48px 56px 56px;
    border: 1px solid var(--border);
    box-shadow: 0 40px 80px -40px rgba(0,0,0,0.35);
  }

  .hv-eyebrow {
    font-family: 'Barlow Semi Condensed', sans-serif;
    font-size: 12px; font-weight: 600; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--violet);
    display: flex; align-items: center; gap: 12px;
    margin-bottom: 28px;
  }
  .hv-eyebrow .dot { width: 8px; height: 8px; background: var(--violet); display: inline-block; }

  /* Typographic headline — 3 lines staircased, navy, accent word highlighted */
  .hv-headline {
    font-family: 'Barlow', sans-serif;
    font-weight: 600;
    font-size: 48px;
    line-height: 1.08;
    letter-spacing: -0.015em;
    color: var(--navy);
    margin-bottom: 28px;
    display: flex; flex-direction: column; align-items: flex-start;
    gap: 2px;
  }
  .hv-line { display: block; }
  .hv-line:nth-child(2) { padding-left: 28px; }
  .hv-line:nth-child(3) { padding-left: 8px; }

  /* Accent line — subtle violet highlight, white text, still reads as part of the stack */
  .hv-line-accent {
    display: inline-block;
    background: var(--violet);
    color: white;
    padding: 2px 16px;
  }

  .hv-sub {
    font-size: 16px; line-height: 1.55;
    color: var(--text-mid);
    margin-bottom: 32px;
    max-width: 480px;
  }
  .hv-cta-row { display: flex; align-items: center; gap: 28px; flex-wrap: wrap; }
  .hv-cta {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 14px 28px;
    font-family: 'Barlow', sans-serif;
    font-size: 15px; font-weight: 600;
    color: white; background: var(--navy);
    text-decoration: none; border: none; border-radius: 1px;
    transition: background 0.15s;
  }
  .hv-cta:hover { background: var(--violet); }
  .hv-link {
    color: var(--text-mid);
    font-size: 15px; font-weight: 500; text-decoration: none;
    border-bottom: 1px solid var(--border);
    padding-bottom: 4px;
    transition: color .15s, border-color .15s;
  }
  .hv-link:hover { color: var(--navy); border-color: var(--navy); }

  @media (max-width: 1024px) {
    .hv-overlay { left: 40px; padding: 40px; width: min(560px, calc(100vw - 80px)); }
    .hv-headline { font-size: 38px; }
  }
  @media (max-width: 768px) {
    .hero-video { padding-top: 48px; }
    .hv-media { height: 56vh; }
    .hv-overlay {
      position: relative;
      left: 0; bottom: auto;
      transform: none;
      width: 100%;
      border: 0; border-top: 1px solid var(--border);
      box-shadow: none;
      padding: 40px 24px 48px;
    }
    .hv-headline { font-size: 30px; }
    .hv-line:nth-child(2) { padding-left: 16px; }
    .hv-line:nth-child(3) { padding-left: 0; }
  }
</style>
