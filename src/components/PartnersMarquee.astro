---
import A5cBar from './A5cBar.astro';

interface Props {
  label?: string;
  partners?: string[];
  /** Render the A5c color bar at the top edge of the section as a divider. Default true. */
  topBar?: boolean;
}
const {
  label = 'Who we work with',
  partners = [
    'OpenAI',
    'Columbia University',
    'MyFitnessPal',
    'Coupang',
    'ISEG',
    'Sonae',
    'José de Mello',
    'Co-Created',
    'Unicorn Factory',
  ],
  topBar = true,
} = Astro.props;
---
<section class:list={['partners-marquee', { 'pm-with-topbar': topBar }]}>
  {topBar && <A5cBar flush />}
  <div class="pm-body">
    <div class="pm-label">{label}</div>
    <div class="pm-track" aria-label={label}>
      <div class="pm-row">
        {partners.map((p) => <span class="pm-logo">{p}</span>)}
        {partners.map((p) => <span class="pm-logo" aria-hidden="true">{p}</span>)}
      </div>
    </div>
  </div>
</section>

<style>
  .partners-marquee {
    background: var(--warm-white);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
    position: relative;
  }
  /* When the A5c bar is the top divider, drop the border (the bar replaces it) */
  .partners-marquee.pm-with-topbar { border-top: 0; }

  .pm-body { padding: 72px 0 84px; }

  .pm-label {
    text-align: center;
    color: var(--text-light);
    font-family: 'Barlow Semi Condensed', sans-serif;
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 36px;
  }
  .pm-track {
    position: relative;
    mask-image: linear-gradient(to right, transparent 0, #000 8%, #000 92%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0, #000 8%, #000 92%, transparent 100%);
  }
  .pm-row {
    display: flex;
    gap: 64px;
    width: max-content;
    animation: pm-scroll 42s linear infinite;
  }
  .pm-logo {
    flex-shrink: 0;
    white-space: nowrap;
    font-family: 'Barlow Semi Condensed', sans-serif;
    font-weight: 500;
    font-size: 22px;
    letter-spacing: -0.005em;
    color: var(--text-mid);
    opacity: 0.72;
  }
  @keyframes pm-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .pm-row {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
      width: 100%;
      gap: 28px 44px;
      padding: 0 24px;
    }
    .pm-row > span[aria-hidden="true"] { display: none; }
    .pm-track { mask-image: none; -webkit-mask-image: none; }
  }
  @media (max-width: 768px) {
    .pm-body { padding: 48px 0 56px; }
    .pm-label { margin-bottom: 24px; }
    .pm-logo { font-size: 18px; }
    .pm-row { gap: 44px; }
  }
</style>
