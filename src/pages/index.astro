---
import Base from '../layouts/Base.astro';
import ArrowSquare from '../components/ArrowSquare.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Quote from '../components/Quote.astro';
import A5cBar from '../components/A5cBar.astro';
import PartnersMarquee from '../components/PartnersMarquee.astro';
---

<Base title="Build Something Real" description="Two-week summer innovation programs for high school students in NYC, Lisbon, Porto, and Seoul. Work on real business challenges with experienced practitioners." navVariant="light">

  <!-- HERO -->
  <section class="lp-hero">
    <div class="lp-hero-label">
      <span class="dot"></span>
      Summer 2026 · Four Cities · Three Tracks
    </div>
    <h1>Two Weeks to Build Something That Matters</h1>
    <div class="lp-hero-body">
      <div>
        <p class="lp-hero-text"><span class="lead">Hudson Lab is a summer program where high school students work like founders.</span> Pick a track — product, business, or go-to-market — and spend two weeks building a real project with practitioners who've done it for a living. Not a simulation. Not a lecture series. Actual work, in an actual city, with people who will tell you the truth.</p>
      </div>
      <div class="lp-hero-facts">
        <div class="lp-fact"><span class="v">4 Cities</span><span class="d">NYC · Lisbon · Porto · Seoul</span></div>
        <div class="lp-fact"><span class="v">3 Tracks</span><span class="d">Product · Business · Go-to-Market</span></div>
        <div class="lp-fact"><span class="v">2 Weeks</span><span class="d">Full-time, intensive, studio-based</span></div>
        <div class="lp-cta-row">
          <a href="/admissions" class="btn-dark">
            <ArrowSquare />
            Apply Now
          </a>
          <a href="/programs" class="text-link">Learn more about the program</a>
        </div>
      </div>
    </div>
  </section>

  <!-- PHOTO -->
  <div class="photo-full">
    <span class="photo-placeholder">Wide environmental — students in studio, natural light, candid</span>
  </div>

  <!-- A5c bar after hero photo -->
  <div class="a5c-inline">
    <div style="flex: 6; background: var(--violet);"></div>
    <div style="flex: 5; background: var(--blue);"></div>
    <div style="flex: 4; background: var(--coral);"></div>
    <div style="flex: 3; background: var(--pop);"></div>
    <div style="flex: 2; background: var(--green);"></div>
    <div style="flex: 2; background: var(--navy);"></div>
  </div>

  <!-- PREMISE -->
  <section class="lp-premise">
    <div class="lp-premise-inner">
      <div class="mark" style="width: 6px; height: 48px; background: var(--coral); margin-bottom: 28px;"></div>
      <h2>Most Programs Teach You About Business. We Put You Inside One.</h2>
      <p><span class="lead">The gap between learning and doing is where most education fails.</span> You can study product management for a semester and never prototype anything. You can ace a marketing exam and never run a campaign.</p>
      <p>Hudson Lab closes that gap. Every day, you're making something — and getting honest feedback from people who build things professionally. By the end, you'll have a portfolio of work that proves what you can do, not what you memorized.</p>
    </div>
  </section>

  <!-- PARTNERS MARQUEE — credibility anchor between premise and tracks -->
  <PartnersMarquee />

  <!-- TRACKS -->
  <section class="tracks-section">
    <div class="tracks-label label-sm">Three Tracks</div>
    <div class="tracks-grid bordered-grid">
      <div class="track-cell">
        <div class="t-icon c-icon"><svg viewBox="0 0 24 24" stroke="var(--coral)" width="20" height="20"><rect x="3" y="3" width="18" height="18"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="9" x2="9" y2="21"/></svg></div>
        <h3>Product</h3>
        <div class="t-sub">Design & Build</div>
        <p>Turn problems into prototypes. User research, information architecture, interaction design. You'll ship something testable by week two.</p>
      </div>
      <div class="track-cell">
        <div class="t-icon c-icon"><svg viewBox="0 0 24 24" stroke="var(--green)" width="20" height="20"><path d="M4 20 L12 4 L20 20 Z"/><line x1="8" y1="14" x2="16" y2="14"/></svg></div>
        <h3>Business</h3>
        <div class="t-sub">Model & Validate</div>
        <p>Make the numbers work. Revenue models, unit economics, competitive analysis. Build a case that could survive a board meeting.</p>
      </div>
      <div class="track-cell">
        <div class="t-icon c-icon"><svg viewBox="0 0 24 24" stroke="var(--blue)" width="20" height="20"><polyline points="4 17 10 11 14 15 20 9"/><line x1="15" y1="9" x2="20" y2="9"/><line x1="20" y1="9" x2="20" y2="14"/></svg></div>
        <h3>Go-to-Market</h3>
        <div class="t-sub">Launch & Grow</div>
        <p>Get it in front of people. Positioning, channel strategy, campaign execution. Launch something real and measure what happens.</p>
      </div>
    </div>
  </section>

  <!-- PHOTO PAIR -->
  <div class="photo-pair">
    <div class="photo-pair-item"><span class="photo-placeholder">Students presenting / crit session</span></div>
    <div class="photo-pair-item"><span class="photo-placeholder">City street / cultural moment</span></div>
  </div>

  <!-- QUOTE -->
  <Quote
    text="I came in thinking I wanted to do product. By day four, I realized I was a business person who happened to like design. That cross-track exposure changed everything."
    attribution="NYC 2025"
  />

  <!-- CITIES -->
  <section class="cities-section">
    <SectionHeader title="Four Cities" color="blue" />

    <div class="cities-grid bordered-grid">
      <div class="city-card">
        <div class="city-card-photo"><span class="photo-placeholder">NYC</span><div class="c-mark" style="background: var(--violet);"></div></div>
        <div class="city-card-info">
          <div class="c-name">New York</div>
          <div class="c-dates">June 27 – July 11</div>
          <div class="c-desc">The density forces clarity. Build in a city where every block is a market.</div>
          <a href="/program/nyc" class="icon-link">View program <span class="mini-arrow"><svg viewBox="0 0 12 12" width="12" height="12"><line x1="2" y1="6" x2="10" y2="6"/><line x1="6.5" y1="3" x2="10" y2="6"/><line x1="6.5" y1="9" x2="10" y2="6"/></svg></span></a>
        </div>
      </div>
      <div class="city-card">
        <div class="city-card-photo"><span class="photo-placeholder">Lisbon</span><div class="c-mark" style="background: var(--blue);"></div></div>
        <div class="city-card-info">
          <div class="c-name">Lisbon</div>
          <div class="c-dates">July 13 – July 25</div>
          <div class="c-desc">Europe's startup capital, at a human scale.</div>
          <a href="/program/lisbon" class="icon-link">View program <span class="mini-arrow"><svg viewBox="0 0 12 12" width="12" height="12"><line x1="2" y1="6" x2="10" y2="6"/><line x1="6.5" y1="3" x2="10" y2="6"/><line x1="6.5" y1="9" x2="10" y2="6"/></svg></span></a>
        </div>
      </div>
      <div class="city-card">
        <div class="city-card-photo"><span class="photo-placeholder">Porto</span><div class="c-mark" style="background: var(--coral);"></div></div>
        <div class="city-card-info">
          <div class="c-name">Porto</div>
          <div class="c-dates">July 13 – July 25</div>
          <div class="c-desc">Craft culture meets entrepreneurship.</div>
          <a href="/program/porto" class="icon-link">View program <span class="mini-arrow"><svg viewBox="0 0 12 12" width="12" height="12"><line x1="2" y1="6" x2="10" y2="6"/><line x1="6.5" y1="3" x2="10" y2="6"/><line x1="6.5" y1="9" x2="10" y2="6"/></svg></span></a>
        </div>
      </div>
      <div class="city-card">
        <div class="city-card-photo"><span class="photo-placeholder">Seoul</span><div class="c-mark" style="background: var(--pop);"></div></div>
        <div class="city-card-info">
          <div class="c-name">Seoul</div>
          <div class="c-dates">July 27 – Aug 8</div>
          <div class="c-desc">Where technology is culture.</div>
          <a href="/program/seoul" class="icon-link">View program <span class="mini-arrow"><svg viewBox="0 0 12 12" width="12" height="12"><line x1="2" y1="6" x2="10" y2="6"/><line x1="6.5" y1="3" x2="10" y2="6"/><line x1="6.5" y1="9" x2="10" y2="6"/></svg></span></a>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW TO APPLY -->
  <section class="how-band">
    <div class="how-inner">
      <div class="how-label-col">
        <div class="section-mark" style="background: var(--green);"></div>
        <h2>How to Apply</h2>
      </div>
      <div class="how-steps">
        <div class="how-step"><div class="s-num label-sm" style="color: var(--violet);">01 · Apply</div><h3>15-minute application</h3><p>No test scores, no transcripts. Tell us what you're curious about.</p></div>
        <div class="how-step"><div class="s-num label-sm" style="color: var(--coral);">02 · Review</div><h3>Decision in 5 days</h3><p>We read every application. Looking for curiosity and initiative.</p></div>
        <div class="how-step"><div class="s-num label-sm" style="color: var(--blue);">03 · Enroll</div><h3>Secure your spot</h3><p>Deposit holds your place. Financial aid available.</p></div>
      </div>
    </div>
  </section>

  <!-- FOR PARENTS -->
  <section class="parents-section">
    <span class="parents-tag">For Parents</span>
    <h2>Your Questions Are the Right Questions</h2>
    <div class="parents-text">
      <p><span class="lead">We know you're reading this and thinking about safety, supervision, and whether this is worth the investment.</span> Good. We'd be worried if you weren't.</p>
      <p>Adult facilitators are present during all program hours. Evening activities are optional and supervised when organized by us. Housing is arranged through vetted local partners. We maintain small cohorts because the student-to-facilitator ratio matters more than the headcount.</p>
      <p>The program costs real money and we offer real financial aid. We'll be transparent about both.</p>
      <a href="/parents" class="parents-link">Read the full parents guide <ArrowSquare size="small" /></a>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-dark">
    <div class="cta-dark-inner">
      <div>
        <h2>Build something real<br>this summer.</h2>
        <p>Rolling admissions. 15-minute application. Decisions within 5 days.</p>
      </div>
      <a href="/admissions" class="btn-light">
        <ArrowSquare />
        Start Your Application
      </a>
    </div>
  </section>

</Base>

<style>
  /* ===== LP HERO ===== */
  .lp-hero {
    padding: 180px 80px 0;
    max-width: 1200px; margin: 0 auto;
  }
  .lp-hero-label {
    font-family: 'Barlow Semi Condensed', sans-serif;
    font-size: 13px; font-weight: 600;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--violet); margin-bottom: 28px;
    display: flex; align-items: center; gap: 12px;
  }
  .dot { width: 8px; height: 8px; background: var(--violet); display: inline-block; }
  .lp-hero h1 {
    font-size: 56px; font-weight: 600;
    line-height: 1.08; color: var(--navy);
    max-width: 780px; margin-bottom: 32px;
    letter-spacing: -0.01em;
  }
  .lp-hero-body {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 80px; padding-bottom: 80px;
  }
  .lp-hero-text {
    font-size: 18px; line-height: 1.65;
    color: var(--text-mid); max-width: 460px;
  }
  .lp-hero-facts { display: flex; flex-direction: column; justify-content: flex-end; }
  .lp-fact {
    display: flex; align-items: baseline; gap: 16px;
    padding: 16px 0; border-top: 1px solid var(--border);
  }
  .lp-fact .v { font-size: 18px; font-weight: 600; color: var(--navy); min-width: 120px; }
  .lp-fact .d { font-size: 15px; color: var(--text-mid); }
  .lp-cta-row { display: flex; align-items: center; gap: 20px; padding-top: 12px; }

  /* ===== PHOTO ===== */
  .photo-full {
    width: 100%; height: 520px;
    background: var(--bg-subtle);
    display: flex; align-items: center; justify-content: center;
  }
  .photo-full span { border: 1px solid var(--border); padding: 16px 32px; }

  /* A5c inline (after hero photo) */
  .a5c-inline { display: flex; height: 5px; width: 100%; }

  /* ===== PREMISE ===== */
  .lp-premise { max-width: 1200px; margin: 0 auto; padding: 120px 80px; }
  .lp-premise-inner { max-width: 680px; }
  .lp-premise h2 {
    font-size: 34px; font-weight: 600;
    line-height: 1.2; color: var(--navy); margin-bottom: 20px;
  }
  .lp-premise p {
    font-size: 18px; line-height: 1.7;
    color: var(--text-mid); margin-bottom: 16px;
  }

  /* ===== TRACKS ===== */
  .tracks-section { max-width: 1200px; margin: 0 auto; padding: 0 80px 120px; }
  .tracks-label { margin-bottom: 32px; color: var(--text-light); }
  .tracks-grid { display: grid; grid-template-columns: repeat(3, 1fr); }
  .track-cell { padding: 48px 40px; }
  .t-icon { margin-bottom: 24px; }
  .track-cell h3 { font-size: 22px; font-weight: 600; color: var(--navy); margin-bottom: 4px; }
  .t-sub { font-size: 15px; font-weight: 500; color: var(--text-light); margin-bottom: 14px; }
  .track-cell p { font-size: 15px; line-height: 1.6; color: var(--text-mid); }

  /* ===== PHOTO PAIR ===== */
  .photo-pair {
    display: grid; grid-template-columns: 2fr 1fr;
    gap: 1px; height: 400px;
  }
  .photo-pair-item {
    display: flex; align-items: center; justify-content: center;
    background: var(--bg-subtle);
  }
  .photo-pair-item:nth-child(2) { background: #e2e0dc; }

  /* ===== CITIES ===== */
  .cities-section { max-width: 1200px; margin: 0 auto; padding: 0 80px 120px; }
  .cities-section .section-header { margin-bottom: 36px; }
  .cities-grid { display: grid; grid-template-columns: repeat(4, 1fr); }
  .city-card { cursor: pointer; transition: background 0.15s; }
  .city-card:hover { background: rgba(0,0,0,0.015); }
  .city-card-photo {
    width: 100%; aspect-ratio: 3/2;
    display: flex; align-items: center; justify-content: center;
    position: relative; border-bottom: 1px solid var(--border);
    background: var(--bg-subtle);
  }
  .c-mark { position: absolute; bottom: -1px; left: 24px; width: 40px; height: 4px; }
  .city-card-info { padding: 24px 24px 28px; }
  .c-name { font-size: 20px; font-weight: 600; color: var(--navy); margin-bottom: 2px; }
  .c-dates { font-size: 14px; color: var(--text-light); margin-bottom: 12px; }
  .c-desc { font-size: 14px; color: var(--text-mid); line-height: 1.5; margin-bottom: 16px; }
  .mini-arrow { display: inline-flex; align-items: center; justify-content: center; }
  .mini-arrow svg { stroke: currentColor; stroke-width: 2; fill: none; stroke-linecap: square; }

  /* ===== HOW TO APPLY ===== */
  .how-band { border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .how-inner {
    max-width: 1200px; margin: 0 auto; padding: 0 80px;
    display: grid; grid-template-columns: 280px 1fr;
  }
  .how-label-col { padding: 64px 0; display: flex; align-items: flex-start; gap: 20px; }
  .how-label-col h2 { font-size: 28px; font-weight: 600; color: var(--navy); }
  .how-steps {
    display: grid; grid-template-columns: repeat(3, 1fr);
    border-left: 1px solid var(--border);
  }
  .how-step { padding: 64px 32px; border-right: 1px solid var(--border); }
  .s-num { margin-bottom: 12px; }
  .how-step h3 { font-size: 17px; font-weight: 600; color: var(--navy); margin-bottom: 6px; }
  .how-step p { font-size: 14px; line-height: 1.55; color: var(--text-mid); }

  /* ===== FOR PARENTS ===== */
  .parents-section { max-width: 1200px; margin: 0 auto; padding: 120px 80px; }
  .parents-tag {
    display: inline-block; padding: 4px 12px; margin-bottom: 24px;
    font-family: 'Barlow Semi Condensed', sans-serif;
    font-size: 12px; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: white; background: var(--violet);
  }
  .parents-section h2 { font-size: 32px; font-weight: 600; color: var(--navy); margin-bottom: 20px; max-width: 520px; }
  .parents-text { max-width: 620px; }
  .parents-text p { font-size: 17px; line-height: 1.7; color: var(--text-mid); margin-bottom: 16px; }
  .parents-link {
    display: inline-flex; align-items: center; gap: 10px;
    margin-top: 12px; font-size: 15px; font-weight: 600;
    color: var(--navy); text-decoration: none;
  }

  /* ===== CTA ===== */
  .cta-dark { background: var(--dark); padding: 100px 80px; }
  .cta-dark-inner {
    max-width: 1200px; margin: 0 auto;
    display: flex; align-items: center; justify-content: space-between;
  }
  .cta-dark h2 { font-size: 38px; font-weight: 600; color: white; line-height: 1.15; margin-bottom: 12px; }
  .cta-dark p { font-size: 17px; color: rgba(255,255,255,0.45); max-width: 420px; }

  @media (max-width: 768px) {
    .lp-hero { padding: 120px 24px 0; }
    .lp-hero h1 { font-size: 36px; max-width: 100%; }
    .lp-hero-body { grid-template-columns: 1fr; gap: 40px; padding-bottom: 40px; }
    .lp-hero-text { font-size: 16px; max-width: 100%; }
    .lp-cta-row { flex-direction: column; align-items: flex-start; gap: 12px; }
    .photo-full { height: 280px; }
    .lp-premise { padding: 80px 24px; }
    .lp-premise h2 { font-size: 28px; }
    .lp-premise p { font-size: 16px; }
    .tracks-section { padding: 0 24px 80px; }
    .tracks-grid { grid-template-columns: 1fr; }
    .photo-pair { grid-template-columns: 1fr; height: auto; }
    .photo-pair-item { height: 200px; }
    .quote-warm { padding: 60px 24px; }
    .quote-warm blockquote { font-size: 20px; }
    .cities-section { padding: 0 24px 80px; }
    .cities-section .section-header { margin-bottom: 24px; }
    .cities-grid { grid-template-columns: 1fr 1fr; }
    .how-band .how-inner { grid-template-columns: 1fr; padding: 0 24px; }
    .how-label-col { padding: 40px 0 0; }
    .how-steps { grid-template-columns: 1fr; border-left: none; }
    .how-step { padding: 24px 0; border-right: none; border-bottom: 1px solid var(--border); }
    .parents-section { padding: 80px 24px; }
    .parents-section h2 { font-size: 26px; }
    .cta-dark { padding: 60px 24px; }
    .cta-dark-inner { flex-direction: column; gap: 32px; text-align: center; align-items: center; }
    .cta-dark h2 { font-size: 28px; }
    .a5c-inline { height: 4px; }
  }
  @media (max-width: 480px) {
    .cities-grid { grid-template-columns: 1fr; }
  }

</style>


