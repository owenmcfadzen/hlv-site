---
import Base from '../layouts/Base.astro';
import ArrowSquare from '../components/ArrowSquare.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Quote from '../components/Quote.astro';
import A5cBar from '../components/A5cBar.astro';
import PartnersMarquee from '../components/PartnersMarquee.astro';
import HeroVideo from '../components/HeroVideo.astro';
import PremiseDark from '../components/PremiseDark.astro';
import SpecialtiesGrid from '../components/SpecialtiesGrid.astro';
import CityLocations from '../components/CityLocations.astro';
import FAQList from '../components/FAQList.astro';
---

<Base title="Build Something Real" description="Two-week summer innovation programs for high school students in NYC, Lisbon, Porto, and Seoul. Work on real business challenges with experienced practitioners." navVariant="light">

  <!-- HERO (new) — video background + dark overlay card, bottom-left, hangs 1/3 into next section -->
  <HeroVideo />

  <!-- PREMISE DARK (new) — "What Hudson Lab is" on a dark surface to receive the hero overlay -->
  <PremiseDark />



  <!-- PARTNERS MARQUEE — credibility anchor between premise and tracks -->
  <PartnersMarquee />

  <!-- SPECIALTIES GRID (new) — 3×3: 6 foundational + 3 optional specialties -->
  <SpecialtiesGrid />

  <!-- PHOTO PAIR -->
  <div class="photo-pair">
    <div class="photo-pair-item"><img src="/img/studio-team.webp" alt="Student cohort presenting at Columbia" loading="lazy" /></div>
    <div class="photo-pair-item"><img src="/img/studio-work.webp" alt="Project work in progress" loading="lazy" /></div>
  </div>

  <!-- QUOTE -->
  <Quote
    text="I came in thinking I wanted to do product. By day four, I realized I was a business person who happened to like design. That cross-track exposure changed everything."
    attribution="NYC 2025"
  />

  <!-- CITIES (full-width alternating rows) -->
  <CityLocations />

  <!-- INTENT CTA — dark emotional fulcrum. Full-bleed layout: text on the left
       with site gutter; photo grid fills the right third, edge to edge. -->
  <section class="intent-cta">
    <div class="intent-copy">
      <div class="intent-copy-inner">
        <div class="hl-stack">
          <span class="hl-block" style="background: var(--violet);">Make this summer</span>
          <span class="hl-block" style="background: var(--pop); color: var(--navy); margin-left: 32px;">count.</span>
        </div>
        <p class="intent-text"><span class="lead">Two weeks that sit differently on a résumé — and in your head.</span> Applications for Summer 2026 are open now. Rolling review. Decisions within five days.</p>
        <div class="intent-cta-row">
          <a href="/admissions" class="btn-light">
            <ArrowSquare size="small" />
            Start your application
          </a>
          <a href="mailto:hello@hudsonlabventures.com" class="intent-email">Talk to someone first →</a>
        </div>
      </div>
    </div>
    <div class="intent-photos" aria-hidden="true">
      <div class="intent-photo photo-1"><span class="photo-placeholder on-dark">Studio moment</span></div>
      <div class="intent-photo photo-2"><span class="photo-placeholder on-dark">Cohort detail</span></div>
      <div class="intent-photo photo-3"><span class="photo-placeholder on-dark">City at work</span></div>
    </div>
  </section>

  <!-- HOW TO APPLY — quiet procedural detail after the emotional ask -->
  <section class="how-band">
    <div class="how-inner">
      <div class="how-label-col">
        <div class="section-mark" style="background: var(--green);"></div>
        <h2>How to Apply</h2>
      </div>
      <div class="how-steps">
        <div class="how-step"><div class="s-num label-sm" style="color: var(--violet);">01 · Apply</div><h3>15-minute application</h3><p>No test scores, no transcripts. Tell us what you're curious about.</p></div>
        <div class="how-step"><div class="s-num label-sm" style="color: var(--coral);">02 · Review</div><h3>Decision in 5 days</h3><p>We read every application. Looking for curiosity and initiative.</p></div>
        <div class="how-step"><div class="s-num label-sm" style="color: var(--blue);">03 · Enroll</div><h3>Secure your spot</h3><p>Deposit holds your place. Financial aid available.</p></div>
      </div>
    </div>
  </section>

  <!-- CARE — unified trust section: intro + accordion FAQ + personal signature -->
  <section class="care-section">
    <div class="care-inner">
      <div class="care-open">
        <div class="care-mark"><span style="background:var(--violet)"></span><span style="background:var(--pop)"></span><span style="background:var(--coral)"></span></div>
        <h2>We know what you're trusting us with.</h2>
        <p><span class="lead">Your child's summer. The shape of their self-belief. A real investment of time and money — often weeks away from home.</span> We don't take any of it lightly, and we'd be worried if you did. Here are the questions families ask us most, and honest answers.</p>
      </div>

      <div class="care-faq">
        <details class="care-item" open>
          <summary><span class="care-q">Is this safe? How is my child supervised?</span><span class="care-toggle" aria-hidden="true"><svg viewBox="0 0 14 14" width="14" height="14"><line x1="2" y1="7" x2="12" y2="7"/><line class="v-stroke" x1="7" y1="2" x2="7" y2="12"/></svg></span></summary>
          <div class="care-a"><span class="lead">Adult facilitators are present during all program hours.</span> Evening activities are optional and supervised when organized by us. Housing is arranged through vetted local partners. Small cohorts mean student-to-facilitator ratios we can keep personal — not headcounts we have to manage.</div>
        </details>
        <details class="care-item">
          <summary><span class="care-q">What does it cost, and is there real financial aid?</span><span class="care-toggle" aria-hidden="true"><svg viewBox="0 0 14 14" width="14" height="14"><line x1="2" y1="7" x2="12" y2="7"/><line class="v-stroke" x1="7" y1="2" x2="7" y2="12"/></svg></span></summary>
          <div class="care-a"><span class="lead">Programs cost real money; we offer real financial aid.</span> Full breakdown on the <a href="/admissions">admissions page</a>. We're transparent either way — ask us directly if something isn't clear.</div>
        </details>
        <details class="care-item">
          <summary><span class="care-q">Who's this designed for?</span><span class="care-toggle" aria-hidden="true"><svg viewBox="0 0 14 14" width="14" height="14"><line x1="2" y1="7" x2="12" y2="7"/><line class="v-stroke" x1="7" y1="2" x2="7" y2="12"/></svg></span></summary>
          <div class="care-a"><span class="lead">High-school students ages 14–19.</span> NYC (Columbia) takes rising 9th graders through graduated seniors; international programs take rising 10th graders and older. We look for curiosity and initiative, not test scores.</div>
        </details>
        <details class="care-item">
          <summary><span class="care-q">How selective is it?</span><span class="care-toggle" aria-hidden="true"><svg viewBox="0 0 14 14" width="14" height="14"><line x1="2" y1="7" x2="12" y2="7"/><line class="v-stroke" x1="7" y1="2" x2="7" y2="12"/></svg></span></summary>
          <div class="care-a"><span class="lead">Selective, not competitive.</span> We're building a cohort, not ranking individuals. Every application is read by a human.</div>
        </details>
        <details class="care-item">
          <summary><span class="care-q">What if they're not sure which specialty to pick?</span><span class="care-toggle" aria-hidden="true"><svg viewBox="0 0 14 14" width="14" height="14"><line x1="2" y1="7" x2="12" y2="7"/><line class="v-stroke" x1="7" y1="2" x2="7" y2="12"/></svg></span></summary>
          <div class="care-a"><span class="lead">That's normal.</span> They tell us what interests them on the application. Final selection happens day one, after they've met the cohort and the operator.</div>
        </details>
        <details class="care-item last">
          <summary><span class="care-q">Can we talk to someone before applying?</span><span class="care-toggle" aria-hidden="true"><svg viewBox="0 0 14 14" width="14" height="14"><line x1="2" y1="7" x2="12" y2="7"/><line class="v-stroke" x1="7" y1="2" x2="7" y2="12"/></svg></span></summary>
          <div class="care-a"><span class="lead">Please do.</span> See the note below — write to Cate directly, and you'll hear back from a real person.</div>
        </details>
      </div>

      <div class="care-close">
        <div class="care-portrait"><span class="photo-placeholder">Cate Han</span></div>
        <div class="care-note">
          <p class="lead">Still have questions that only apply to you?</p>
          <p>Write directly — <a href="mailto:cate@hudsonlabventures.com">cate@hudsonlabventures.com</a>. I read everything that comes in, and you'll hear back, usually the same day.</p>
          <p class="care-sig">— Cate Han, Founder</p>
          <svg class="care-signature" viewBox="0 0 200 56" width="150" height="42" aria-hidden="true">
            <path
              d="M6 34 C 10 18, 24 12, 34 22 C 38 28, 28 34, 20 32 C 14 30, 18 22, 26 26 C 36 30, 42 16, 50 30 C 54 18, 60 12, 66 26 C 70 30, 62 34, 56 30 C 56 26, 64 22, 72 28 C 80 34, 86 20, 92 28 C 96 22, 104 18, 108 30 C 106 22, 112 14, 118 26 C 120 30, 116 34, 112 32 C 112 26, 122 22, 132 30 C 140 36, 152 22, 164 30 C 170 34, 176 28, 182 24"
              fill="none" stroke="var(--navy)" stroke-width="1.75"
              stroke-linecap="round" stroke-linejoin="round" opacity="0.78"/>
            <path
              d="M10 46 Q 100 52 180 42"
              fill="none" stroke="var(--navy)" stroke-width="1.25"
              stroke-linecap="round" opacity="0.35"/>
          </svg>
          <a href="/parents" class="care-fullguide">Or read the full parents guide →</a>
        </div>
      </div>
    </div>
  </section>



    


</Base>

<style>
  /* ===== PHOTO PAIR ===== */
  .photo-pair {
    display: grid; grid-template-columns: 2fr 1fr;
    gap: 1px; height: 400px;
  }
  .photo-pair-item {
    display: flex; align-items: center; justify-content: center;
    background: var(--bg-subtle);
    overflow: hidden;
  }
  .photo-pair-item:nth-child(2) { background: #e2e0dc; }
  .photo-pair-item img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* ===== HOW TO APPLY ===== */
  .how-band { border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .how-inner {
    max-width: 1200px; margin: 0 auto; padding: 0 80px;
    display: grid; grid-template-columns: 280px 1fr;
  }
  .how-label-col { padding: 64px 0; display: flex; align-items: flex-start; gap: 20px; }
  .how-label-col h2 { font-size: 28px; font-weight: 600; color: var(--navy); }
  .how-steps {
    display: grid; grid-template-columns: repeat(3, 1fr);
    border-left: 1px solid var(--border);
  }
  .how-step { padding: 64px 32px; border-right: 1px solid var(--border); }
  .s-num { margin-bottom: 12px; }
  .how-step h3 { font-size: 17px; font-weight: 600; color: var(--navy); margin-bottom: 6px; }
  .how-step p { font-size: 14px; line-height: 1.55; color: var(--text-mid); }

  /* ===== FOR PARENTS ===== */
  .parents-section { max-width: 1200px; margin: 0 auto; padding: 120px 80px; }
  .parents-tag {
    display: inline-block; padding: 4px 12px; margin-bottom: 24px;
    font-family: 'Barlow Semi Condensed', sans-serif;
    font-size: 12px; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: white; background: var(--violet);
  }
  .parents-section h2 { font-size: 32px; font-weight: 600; color: var(--navy); margin-bottom: 20px; max-width: 520px; }
  .parents-text { max-width: 620px; }
  .parents-text p { font-size: 17px; line-height: 1.7; color: var(--text-mid); margin-bottom: 16px; }
  .parents-link {
    display: inline-flex; align-items: center; gap: 10px;
    margin-top: 12px; font-size: 15px; font-weight: 600;
    color: var(--navy); text-decoration: none;
  }

  /* ===== CTA ===== */
  .cta-dark { background: var(--dark); padding: 100px 80px; }
  .cta-dark-inner {
    max-width: 1200px; margin: 0 auto;
    display: flex; align-items: center; justify-content: space-between;
  }
  .cta-dark h2 { font-size: 38px; font-weight: 600; color: white; line-height: 1.15; margin-bottom: 12px; }
  .cta-dark p { font-size: 17px; color: rgba(255,255,255,0.45); max-width: 420px; }

  @media (max-width: 768px) {
    .photo-pair { grid-template-columns: 1fr; height: auto; }
    .photo-pair-item { height: 200px; }
    .quote-warm { padding: 60px 24px; }
    .quote-warm blockquote { font-size: 20px; }
    .how-band .how-inner { grid-template-columns: 1fr; padding: 0 24px; }
    .how-label-col { padding: 40px 0 0; }
    .how-steps { grid-template-columns: 1fr; border-left: none; }
    .how-step { padding: 24px 0; border-right: none; border-bottom: 1px solid var(--border); }
    .parents-section { padding: 80px 24px; }
    .parents-section h2 { font-size: 26px; }
    .cta-dark { padding: 60px 24px; }
    .cta-dark-inner { flex-direction: column; gap: 32px; text-align: center; align-items: center; }
    .cta-dark h2 { font-size: 28px; }
  }
  @media (max-width: 480px) {
  }


  /* ===== INTENT CTA (dark emotional fulcrum) =====
     Full-bleed: section itself is a 2-col grid. Text has internal padding,
     photo grid bleeds to the right edge of the viewport and fills the
     section top-to-bottom — no gutter, no padding. */
  .intent-cta { background: var(--dark); color: white; padding: 0; position: relative;
    display: grid; grid-template-columns: 1fr 33.333%; align-items: stretch; }

  .intent-copy { padding: 120px 80px; display: flex; align-items: center; justify-content: flex-end; }
  .intent-copy-inner { max-width: 640px; width: 100%; }
  .intent-copy .hl-stack { margin-bottom: 40px; }
  .intent-copy .hl-block { font-size: 56px; padding: 10px 28px; letter-spacing: -0.01em; }
  .intent-text { font-size: 19px; line-height: 1.55; color: rgba(255,255,255,0.75); max-width: 620px; margin-bottom: 48px; }
  .intent-text .lead { color: white; font-weight: 500; }
  .intent-cta-row { display: flex; align-items: center; gap: 32px; flex-wrap: wrap; }
  .intent-email { color: rgba(255,255,255,0.7); font-size: 15px; font-weight: 500; text-decoration: none; border-bottom: 1px solid rgba(255,255,255,0.25); padding-bottom: 4px; transition: color .15s, border-color .15s; }
  .intent-email:hover { color: white; border-color: white; }

  /* Right-third photo grid: 2 cols × 3 rows. Photos zigzag L-R-L.
     Unused cells stay transparent (dark bg shows through).
     No aspect-ratio — cells stretch to fill the section height. */
  .intent-photos { display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: repeat(3, 1fr); gap: 1px; height: 100%; align-self: stretch; }
  .intent-photo { background: #1e1e22; display: flex; align-items: center; justify-content: center; min-height: 0; }
  .intent-photo .photo-placeholder { border: 0; padding: 0; font-size: 10px; color: rgba(255,255,255,0.22); }
  .intent-photo.photo-1 { grid-column: 1; grid-row: 1; }
  .intent-photo.photo-2 { grid-column: 2; grid-row: 2; }
  .intent-photo.photo-3 { grid-column: 1; grid-row: 3; }

  @media (max-width: 1024px) {
    .intent-cta { grid-template-columns: 1fr 40%; }
    .intent-copy { padding: 100px 48px; }
  }
  @media (max-width: 768px) {
    .intent-cta { grid-template-columns: 1fr; padding: 0; }
    .intent-copy { padding: 72px 24px 40px; justify-content: flex-start; }
    .intent-copy .hl-block { font-size: 32px; padding: 6px 16px; }
    .intent-copy .hl-stack > :nth-child(2) { margin-left: 0 !important; }
    .intent-cta-row { gap: 20px; }
    .intent-photos { aspect-ratio: 3 / 2; }
  }


  /* ===== CARE SECTION (trust + omotenashi) ===== */
  .care-section { background: var(--warm-white); padding: 120px 0 140px; border-top: 1px solid var(--border); }
  .care-inner { max-width: 780px; margin: 0 auto; padding: 0 40px; }

  .care-open { margin-bottom: 72px; }
  .care-mark { display: flex; gap: 6px; margin-bottom: 28px; }
  .care-mark span { width: 24px; height: 6px; display: block; }
  .care-open h2 { font-size: 32px; font-weight: 600; color: var(--navy); line-height: 1.15; letter-spacing: -0.01em; margin-bottom: 20px; max-width: 640px; }
  .care-open p { font-size: 17px; line-height: 1.65; color: var(--text-mid); max-width: 640px; }

  /* FAQ accordion */
  .care-faq { margin-bottom: 96px; }
  .care-item { border-top: 1px solid var(--border); padding: 0; }
  .care-item.last { border-bottom: 1px solid var(--border); }
  .care-item > summary { list-style: none; cursor: pointer; display: flex; align-items: center; justify-content: space-between; gap: 24px; padding: 24px 0; }
  .care-item > summary::-webkit-details-marker { display: none; }
  .care-q { font-size: 18px; font-weight: 600; color: var(--navy); }
  .care-item > summary:hover .care-q { color: var(--violet); }
  .care-toggle { flex-shrink: 0; width: 28px; height: 28px; display: inline-flex; align-items: center; justify-content: center; border: 1px solid var(--border); border-radius: 1px; transition: border-color 0.15s, background 0.15s; }
  .care-item > summary:hover .care-toggle { border-color: var(--violet); }
  .care-toggle svg { stroke: var(--navy); stroke-width: 1.5; fill: none; stroke-linecap: square; }
  .care-item > summary:hover .care-toggle svg { stroke: var(--violet); }
  .care-item .v-stroke { transition: opacity 0.15s; }
  .care-item[open] .v-stroke { opacity: 0; }
  .care-a { font-size: 16px; line-height: 1.65; color: var(--text-mid); max-width: 640px; padding: 0 0 28px; }
  .care-a a { color: var(--navy); border-bottom: 1px solid var(--border); text-decoration: none; }
  .care-a a:hover { color: var(--violet); border-color: var(--violet); }

  /* Personal close */
  .care-close { display: grid; grid-template-columns: 120px 1fr; gap: 32px; align-items: flex-start; padding-top: 48px; border-top: 1px solid var(--border); }
  .care-portrait { width: 120px; height: 120px; background: var(--bg-subtle); display: flex; align-items: center; justify-content: center; }
  .care-note .lead { display: block; font-size: 18px; font-weight: 500; color: var(--navy); margin-bottom: 12px; }
  .care-note p { font-size: 16px; line-height: 1.6; color: var(--text-mid); margin-bottom: 12px; max-width: 560px; }
  .care-note a { color: var(--navy); border-bottom: 1px solid var(--border); text-decoration: none; }
  .care-note a:hover { color: var(--violet); border-color: var(--violet); }
  .care-sig { font-family: 'Barlow Semi Condensed', sans-serif; font-size: 13px; font-weight: 500; letter-spacing: 0.04em; color: var(--text-light); text-transform: uppercase; margin-top: 20px !important; margin-bottom: 20px !important; }
  .care-fullguide { display: inline-block; font-size: 15px; font-weight: 500; color: var(--text-light); text-decoration: none; border-bottom: 1px solid transparent; padding-bottom: 4px; margin-top: 20px; transition: color 0.18s, border-color 0.18s; }
  .care-fullguide:hover { color: var(--navy); border-color: var(--border); }
  .care-signature { display: block; margin-top: 4px; margin-bottom: 4px; }

  @media (max-width: 768px) {
    .care-section { padding: 72px 0 88px; }
    .care-inner { padding: 0 24px; }
    .care-open h2 { font-size: 26px; }
    .care-faq { margin-bottom: 64px; }
    .care-q { font-size: 16px; }
    .care-close { grid-template-columns: 1fr; gap: 24px; }
    .care-portrait { width: 96px; height: 96px; }
  }</style>


