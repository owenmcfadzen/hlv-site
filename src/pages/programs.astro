---
import Base from '../layouts/Base.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ArrowSquare from '../components/ArrowSquare.astro';
---

<Base title="Programs" description="Compare Hudson Lab Ventures summer programs across four cities. Same curriculum, different contexts. NYC, Lisbon, Porto, and Seoul." navVariant="light" navActive="program">

  <!-- HERO — short, then straight to cities -->
  <section class="pg-hero">
    <h1>Summer 2026 Programs</h1>
    <p class="pg-sub"><span class="lead">Four cities. Same curriculum. Choose yours.</span> Every program runs the same rigorous framework — what changes is the city, the culture, and the corporate challenge you work on.</p>
  </section>

  <!-- CITIES — full-width alternating rows, impossible to miss -->

  <a href="/program/nyc" class="city-row">
    <div class="city-photo" style="background:#e8e6e0;">
      <span class="photo-placeholder">NYC — Manhattan, street level</span>
      <div class="city-edge" style="background:var(--violet);"></div>
    </div>
    <div class="city-content">
      <span class="label-sm city-label" style="color:var(--violet);">New York City</span>
      <h2>New York</h2>
      <p class="city-dates">June 27 – July 11</p>
      <p class="city-desc"><span class="lead">Columbia University campus. Climate Knowledge Initiative.</span> Tackle a real sustainability challenge with Columbia Business School and one of Europe's leading chemical companies.</p>
      <div class="city-meta"><span>24 students</span><span>3 tracks</span><span>Columbia University</span></div>
      <span class="city-link">View NYC Program →</span>
    </div>
  </a>

  <a href="/program/lisbon" class="city-row reverse">
    <div class="city-photo" style="background:#e2e0dc;">
      <span class="photo-placeholder">Lisbon — tram, golden light</span>
      <div class="city-edge right" style="background:var(--blue);"></div>
    </div>
    <div class="city-content">
      <span class="label-sm city-label" style="color:var(--blue);">Lisbon, Portugal</span>
      <h2>Lisbon</h2>
      <p class="city-dates">July 13 – July 25</p>
      <p class="city-desc"><span class="lead">Two challenges: AI in education with José de Mello, or future of retail with Sonae.</span> Europe's startup capital. Founders are accessible, the cost of experimentation is low, and the light makes everything look better.</p>
      <div class="city-meta"><span>20 students</span><span>3 tracks</span><span>José de Mello · Sonae</span></div>
      <span class="city-link">View Lisbon Program →</span>
    </div>
  </a>

  <a href="/program/porto" class="city-row">
    <div class="city-photo" style="background:#e5e3db;">
      <span class="photo-placeholder">Porto — Ribeira, Douro river</span>
      <div class="city-edge" style="background:var(--coral);"></div>
    </div>
    <div class="city-content">
      <span class="label-sm city-label" style="color:var(--coral);">Porto, Portugal</span>
      <h2>Porto</h2>
      <p class="city-dates">July 13 – July 25</p>
      <p class="city-desc"><span class="lead">Craft culture meets entrepreneurship.</span> A deliberately smaller program — two tracks, sixteen students. Porto rewards depth over breadth. Quality matters more than speed here.</p>
      <div class="city-meta"><span>16 students</span><span>2 tracks</span></div>
      <span class="city-link">View Porto Program →</span>
    </div>
  </a>

  <a href="/program/seoul" class="city-row reverse">
    <div class="city-photo" style="background:#e8e6e0;">
      <span class="photo-placeholder">Seoul — neon, Gangnam energy</span>
      <div class="city-edge right" style="background:var(--pop);"></div>
    </div>
    <div class="city-content">
      <span class="label-sm city-label" style="color:#8a7000;">Seoul, South Korea</span>
      <h2>Seoul</h2>
      <p class="city-dates">July 27 – August 8</p>
      <p class="city-desc"><span class="lead">Partner with Coupang — Korea's "Amazon" — on Gen Z e-commerce.</span> The world's most connected market. Korean and international students work side by side. K-culture isn't the backdrop — it's the lens.</p>
      <div class="city-meta"><span>20 students</span><span>3 tracks</span><span>Coupang</span></div>
      <span class="city-link">View Seoul Program →</span>
    </div>
  </a>

  <!-- CALENDAR TIMELINE -->
  <section class="pg-calendar"><div class="mw">
    <SectionHeader title="When" subtitle="All programs run between late June and early August." color="navy" />
    <div class="cal-timeline">
      <div class="cal-months">
        <div class="cal-month" style="flex:2;">June</div>
        <div class="cal-month" style="flex:4;">July</div>
        <div class="cal-month" style="flex:1;">August</div>
      </div>
      <div class="cal-bars">
        <div class="cal-bar-row"><span class="cal-city">NYC</span><div class="cal-track"><div class="cal-block" style="left:14%;width:20%;background:var(--violet);"><span>Jun 27 – Jul 11</span></div></div></div>
        <div class="cal-bar-row"><span class="cal-city">Lisbon</span><div class="cal-track"><div class="cal-block" style="left:36%;width:17%;background:var(--blue);"><span>Jul 13 – Jul 25</span></div></div></div>
        <div class="cal-bar-row"><span class="cal-city">Porto</span><div class="cal-track"><div class="cal-block" style="left:36%;width:17%;background:var(--coral);"><span>Jul 13 – Jul 25</span></div></div></div>
        <div class="cal-bar-row"><span class="cal-city">Seoul</span><div class="cal-track"><div class="cal-block" style="left:56%;width:17%;background:var(--pop);"><span>Jul 27 – Aug 8</span></div></div></div>
      </div>
    </div>
  </div></section>

  <!-- CORE CURRICULUM -->
  <section class="pg-curriculum"><div class="mw">
    <SectionHeader title="What Every Student Learns" subtitle="Regardless of city, track, or specialty — these are the foundations." color="coral" />
    <div class="curr-grid bordered-grid">
      <div class="curr-item"><div class="curr-icon"><svg viewBox="0 0 24 24" stroke="var(--coral)" width="22" height="22"><circle cx="12" cy="8" r="4"/><path d="M4 20 C4 16 8 14 12 14 C16 14 20 16 20 20"/></svg></div><h3>Leadership</h3><p>Take ownership of decisions. Lead a team through ambiguity. Learn that leadership isn't authority — it's initiative.</p></div>
      <div class="curr-item"><div class="curr-icon"><svg viewBox="0 0 24 24" stroke="var(--violet)" width="22" height="22"><circle cx="12" cy="12" r="3"/><path d="M12 2 L12 5 M12 19 L12 22 M2 12 L5 12 M19 12 L22 12"/></svg></div><h3>Critical Thinking</h3><p>Question assumptions. Separate signal from noise. Make decisions under uncertainty with limited information.</p></div>
      <div class="curr-item"><div class="curr-icon"><svg viewBox="0 0 24 24" stroke="var(--blue)" width="22" height="22"><rect x="3" y="3" width="18" height="18"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="12" y1="3" x2="12" y2="21"/></svg></div><h3>Problem Solving</h3><p>Define problems before solving them. Use design thinking to move from mess to clarity to action.</p></div>
      <div class="curr-item"><div class="curr-icon"><svg viewBox="0 0 24 24" stroke="var(--green)" width="22" height="22"><circle cx="8" cy="12" r="4"/><circle cx="16" cy="12" r="4"/></svg></div><h3>Teamwork</h3><p>Work across differences. Give and receive honest feedback. Understand your role in a team and when to step up or step back.</p></div>
      <div class="curr-item"><div class="curr-icon"><svg viewBox="0 0 24 24" stroke="var(--pop)" width="22" height="22"><polygon points="12,2 15,9 22,9 16,14 18,21 12,17 6,21 8,14 2,9 9,9"/></svg></div><h3>Creativity</h3><p>Generate ideas under constraints. Prototype fast. Learn that creativity isn't inspiration — it's a discipline.</p></div>
      <div class="curr-item"><div class="curr-icon"><svg viewBox="0 0 24 24" stroke="var(--navy)" width="22" height="22"><path d="M4 20 L12 4 L20 20"/><line x1="8" y1="14" x2="16" y2="14"/></svg></div><h3>Communication</h3><p>Present to executives. Write clearly. Tell a story with data. Persuade people who don't have to listen.</p></div>
    </div>
  </div></section>

  <!-- QUICK COMPARE -->
  <section class="pg-compare"><div class="mw">
    <SectionHeader title="At a Glance" color="navy" />
    <div class="compare-grid bordered-grid">
      <div class="compare-cell header"></div>
      <div class="compare-cell header"><strong>NYC</strong></div>
      <div class="compare-cell header"><strong>Lisbon</strong></div>
      <div class="compare-cell header"><strong>Porto</strong></div>
      <div class="compare-cell header"><strong>Seoul</strong></div>
      <div class="compare-cell label">Dates</div>
      <div class="compare-cell">Jun 27 – Jul 11</div>
      <div class="compare-cell">Jul 13 – Jul 25</div>
      <div class="compare-cell">Jul 13 – Jul 25</div>
      <div class="compare-cell">Jul 27 – Aug 8</div>
      <div class="compare-cell label">Students</div>
      <div class="compare-cell">24</div>
      <div class="compare-cell">20</div>
      <div class="compare-cell">16</div>
      <div class="compare-cell">20</div>
      <div class="compare-cell label">Tracks</div>
      <div class="compare-cell">3</div>
      <div class="compare-cell">3</div>
      <div class="compare-cell">2</div>
      <div class="compare-cell">3</div>
      <div class="compare-cell label">Partner</div>
      <div class="compare-cell">Columbia CBS</div>
      <div class="compare-cell">José de Mello · Sonae</div>
      <div class="compare-cell">TBA</div>
      <div class="compare-cell">Coupang</div>
      <div class="compare-cell label">Housing</div>
      <div class="compare-cell">Columbia dorms</div>
      <div class="compare-cell">Local partner</div>
      <div class="compare-cell">Local partner</div>
      <div class="compare-cell">Local partner</div>
    </div>
  </div></section>

  
  <!-- SPECIALTIES -->
  <section class="pg-specialties"><div class="mw">
    <SectionHeader title="Specialty Tracks" subtitle="Available at every location. Go deeper in the area that interests you most." color="violet" />
    <div class="spec-grid bordered-grid">
      <div class="spec-card">
        <div class="spec-icon" style="background:rgba(228,108,65,0.08);"><svg viewBox="0 0 24 24" stroke="var(--coral)" width="22" height="22"><rect x="3" y="3" width="18" height="18"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="3" x2="9" y2="21"/></svg></div>
        <h3>AI & Product</h3>
        <p>How AI changes what products can do — and how to build them responsibly.</p>
      </div>
      <div class="spec-card">
        <div class="spec-icon" style="background:rgba(52,199,89,0.08);"><svg viewBox="0 0 24 24" stroke="var(--green)" width="22" height="22"><path d="M4 20 L12 4 L20 20 Z"/><line x1="8" y1="14" x2="16" y2="14"/></svg></div>
        <h3>Venture Finance</h3>
        <p>How startups get funded, how investors think, and how to make a case that survives scrutiny.</p>
      </div>
      <div class="spec-card">
        <div class="spec-icon" style="background:rgba(59,125,216,0.08);"><svg viewBox="0 0 24 24" stroke="var(--blue)" width="22" height="22"><polyline points="4 17 10 11 14 15 20 9"/><line x1="15" y1="9" x2="20" y2="9"/><line x1="20" y1="9" x2="20" y2="14"/></svg></div>
        <h3>Brand Strategy</h3>
        <p>How brands are built, positioned, and communicated — from identity to go-to-market.</p>
      </div>
    </div>
    <div class="spec-callout">
      <div class="spec-callout-text">
        <p><span class="lead">Specialties are optional and available at every location.</span> They add depth alongside your core track — think of them as choosing a focus area. You don't have to pick one to have a great program experience.</p>
        <a href="/specialties" class="btn-dark spec-btn">Learn About Specialty Tracks →</a>
      </div>
    </div>
  </div></section>

  <!-- CTA -->
  <section class="pg-cta"><div class="mw pg-cta-inner">
    <div><h2>Can't decide?</h2><p>Apply to your top two choices. We'll help you find the right fit.</p></div>
    <a href="/admissions" class="btn-dark"><ArrowSquare /> Start Your Application</a>
  </div></section>

</Base>

<style>
  .pg-hero{padding:160px 80px 60px;max-width:1200px;margin:0 auto;}
  .pg-hero h1{font-size:48px;font-weight:600;line-height:1.1;color:var(--navy);max-width:600px;margin-bottom:16px;}
  .pg-sub{font-size:18px;line-height:1.6;color:var(--text-mid);max-width:500px;}

  /* City rows — full width, alternating, dominant */
  .city-row{display:grid;grid-template-columns:1fr 1fr;min-height:440px;text-decoration:none;color:inherit;border-top:1px solid var(--border);transition:background 0.15s;}
  .city-row:last-of-type{border-bottom:1px solid var(--border);}
  .city-row:hover{background:rgba(0,0,0,0.01);}
  .city-row.reverse{direction:rtl;}
  .city-row.reverse>*{direction:ltr;}
  .city-photo{position:relative;display:flex;align-items:center;justify-content:center;min-height:440px;}
  .city-edge{position:absolute;right:0;top:0;bottom:0;width:6px;}
  .city-edge.right{left:0;right:auto;}
  .city-content{padding:56px 72px;display:flex;flex-direction:column;justify-content:center;}
  .city-label{display:block;margin-bottom:4px;}
  .city-content h2{font-size:40px;font-weight:600;color:var(--navy);margin-bottom:4px;line-height:1.1;}
  .city-dates{font-family:'Barlow Semi Condensed',sans-serif;font-size:13px;font-weight:500;letter-spacing:0.04em;color:var(--text-light);margin-bottom:20px;}
  .city-desc{font-size:16px;line-height:1.6;color:var(--text-mid);margin-bottom:16px;max-width:440px;}
  .city-meta{display:flex;gap:16px;margin-bottom:20px;}
  .city-meta span{font-family:'Barlow Semi Condensed',sans-serif;font-size:12px;font-weight:500;letter-spacing:0.04em;color:var(--text-light);}
  .city-link{font-size:15px;font-weight:600;color:var(--navy);}
  .city-row:hover .city-link{color:var(--violet);}

  /* Compare */
  .pg-compare{padding:80px 0 120px;}
  .pg-compare :global(.section-header){margin-bottom:36px;}
  .compare-grid{display:grid;grid-template-columns:140px repeat(4,1fr);}
  .compare-cell{padding:16px 20px;font-size:14px;color:var(--text-mid);}
  .compare-cell.header{font-size:15px;color:var(--navy);padding:20px 20px;}
  .compare-cell.label{font-family:'Barlow Semi Condensed',sans-serif;font-size:12px;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;color:var(--text-light);display:flex;align-items:center;}

  /* CALENDAR */
  .pg-calendar{padding:80px 0;border-top:1px solid var(--border);}
  .pg-calendar :global(.section-header){margin-bottom:36px;}
  .cal-timeline{border:1px solid var(--border);border-radius:2px;overflow:hidden;}
  .cal-months{display:flex;border-bottom:1px solid var(--border);background:var(--bg-subtle);}
  .cal-month{padding:12px 16px;font-family:'Barlow Semi Condensed',sans-serif;font-size:13px;font-weight:600;letter-spacing:0.04em;color:var(--text-light);text-transform:uppercase;border-right:1px solid var(--border);}
  .cal-month:last-child{border-right:none;}
  .cal-bars{padding:16px 0;}
  .cal-bar-row{display:flex;align-items:center;padding:8px 16px;}
  .cal-city{width:80px;font-size:14px;font-weight:600;color:var(--navy);flex-shrink:0;}
  .cal-track{flex:1;height:32px;position:relative;background:rgba(0,0,0,0.02);border-radius:1px;}
  .cal-block{position:absolute;top:0;height:100%;border-radius:1px;display:flex;align-items:center;justify-content:center;}
  .cal-block span{font-size:11px;font-weight:600;color:white;white-space:nowrap;letter-spacing:0.02em;}

  /* CURRICULUM */
  .pg-curriculum{padding:80px 0;border-top:1px solid var(--border);}
  .pg-curriculum :global(.section-header){margin-bottom:36px;}
  .curr-grid{display:grid;grid-template-columns:repeat(3,1fr);}
  .curr-item{padding:32px 28px;}
  .curr-icon{width:40px;height:40px;display:flex;align-items:center;justify-content:center;margin-bottom:14px;}
  .curr-icon svg{stroke-width:1.5;stroke-linecap:square;stroke-linejoin:miter;fill:none;}
  .curr-item h3{font-size:17px;font-weight:600;color:var(--navy);margin-bottom:6px;}
  .curr-item p{font-size:14px;line-height:1.55;color:var(--text-mid);}

  /* SPECIALTIES */
  .pg-specialties{padding:80px 0;border-top:1px solid var(--border);}
  .pg-specialties :global(.section-header){margin-bottom:36px;}
  .spec-grid{display:grid;grid-template-columns:repeat(3,1fr);}
  .spec-card{padding:32px 28px;}
  .spec-icon{width:44px;height:44px;display:flex;align-items:center;justify-content:center;margin-bottom:16px;}
  .spec-icon svg{stroke-width:1.5;stroke-linecap:square;stroke-linejoin:miter;fill:none;}
  .spec-card h3{font-size:18px;font-weight:600;color:var(--navy);margin-bottom:8px;}
  .spec-card p{font-size:14px;line-height:1.55;color:var(--text-mid);}
  .spec-note{margin-top:24px;font-size:15px;color:var(--text-mid);}
  .spec-callout{margin-top:32px;padding:32px 36px;background:rgba(123,79,219,0.04);border-left:4px solid var(--violet);display:flex;align-items:center;justify-content:space-between;}
  .spec-callout-text p{font-size:16px;line-height:1.6;color:var(--text-mid);margin-bottom:16px;max-width:560px;}
  .spec-btn{display:inline-block;background:var(--violet) !important;}

  /* CTA */
  .pg-cta{border-top:1px solid var(--border);padding:80px 0;}
  .pg-cta-inner{display:flex;justify-content:space-between;align-items:center;}
  .pg-cta-inner h2{font-size:32px;font-weight:600;color:var(--navy);margin-bottom:8px;}
  .pg-cta-inner p{font-size:17px;color:var(--text-mid);}

  @media (max-width: 768px) {
    .pg-hero { padding: 120px 24px 40px; }
    .pg-hero h1 { font-size: 32px; }
    .city-row, .city-row.reverse { grid-template-columns: 1fr; direction: ltr; }
    .city-row > * { direction: ltr; }
    .city-photo { min-height: 240px; }
    .city-content { padding: 32px 24px; }
    .city-content h2 { font-size: 30px; }
    .city-edge, .city-edge.right { position: absolute; left: 0; right: 0; top: auto; bottom: 0; width: 100%; height: 4px; }
    .pg-compare { padding: 40px 0 80px; }
    .compare-grid { grid-template-columns: 100px repeat(4, 1fr); font-size: 12px; overflow-x: auto; }
    .compare-cell { padding: 10px 8px; font-size: 11px; }
    .pg-cta { padding: 60px 0; }
    .pg-cta-inner { flex-direction: column; gap: 24px; text-align: center; align-items: center; }
    .pg-cta-inner h2 { font-size: 26px; }
  }

</style>


