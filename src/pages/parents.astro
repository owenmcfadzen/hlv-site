---
import Base from '../layouts/Base.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Quote from '../components/Quote.astro';
import ArrowSquare from '../components/ArrowSquare.astro';
---

<Base title="For Parents" navVariant="light" navActive="parents">

  <!-- HERO — warm, direct, no flash -->
  <section class="par-hero">
    <div class="par-label"><span class="dot"></span> For Parents & Families</div>
    <h1>The Questions You're Asking Are the Right Ones</h1>
    <div class="par-hero-body">
      <div class="par-hero-text">
        <p><span class="lead">You're wondering if this is real, if it's safe, and if it's worth the investment.</span> We'd be worried if you weren't. This page is for you — not a pitch, just the information you need to make a confident decision.</p>
        <p>Hudson Lab Ventures is a two-week summer program where high school students work on real business challenges with guidance from experienced practitioners. The work is serious. The environment is supportive. And the outcomes are things your child can show — a portfolio, not a certificate.</p>
      </div>
    </div>
  </section>

  <!-- WHAT YOUR CHILD WILL DO — clear, concrete -->
  <section class="par-section"><div class="mw">
    <SectionHeader title="What Your Child Will Actually Do" color="coral" />
    <div class="par-prose">
      <p><span class="lead">Every day from 9:00 to 17:00, students work in small teams on a real challenge.</span> Not a simulation — an actual problem that a real company needs solved. They research, prototype, test, and present their work to executives who take it seriously.</p>
      <p>Students choose one of three tracks — Product (design & build), Business (model & validate), or Go-to-Market (launch & grow). They work within their track but learn from all three through daily cross-track critiques. By the end, they have tangible work they can show anyone.</p>
      <p>The program is led by facilitators — experienced practitioners, not teachers. They coach rather than lecture. They ask hard questions rather than give answers. And they hold students to a professional standard, because that's what makes the experience meaningful.</p>
    </div>
  </div></section>

  <!-- PARENT QUOTE -->
  <Quote text="When it came time for college applications, my child's experience at Hudson Lab Ventures was a true point of distinction. But honestly, the bigger change was in how she carried herself afterward." attribution="Parent, NYC 2024" />

  <!-- SAFETY & SUPERVISION — the section parents actually came for -->
  <section class="par-section"><div class="mw">
    <SectionHeader title="Safety & Supervision" color="navy" />
    <div class="par-prose" style="margin-bottom:48px;">
      <p><span class="lead">We take duty of care seriously. Here's exactly how supervision works.</span></p>
    </div>
    <div class="safety-grid bordered-grid">
      <div class="safety-item">
        <h3>During Program Hours</h3>
        <p>Adult facilitators are present from 9:00 to 17:00 every day. We maintain a small student-to-facilitator ratio so every student gets individual attention. All program activities are supervised.</p>
      </div>
      <div class="safety-item">
        <h3>Housing</h3>
        <p>In NYC, students stay in Columbia University residence halls with 24/7 security and live-in Resident Advisors. International programs use vetted local housing with on-site support staff. Day-student options are available at every location.</p>
      </div>
      <div class="safety-item">
        <h3>Evenings & Free Time</h3>
        <p>Evenings are free but structured. HLV-organized activities are always supervised. When students go out independently, we use a buddy system and require check-ins. Curfews are enforced at all residential programs.</p>
      </div>
      <div class="safety-item">
        <h3>Communication</h3>
        <p>Parents receive a welcome packet with emergency contacts, daily schedules, and facilitator information before the program starts. We're reachable by phone and email throughout — and we respond like humans, not form letters.</p>
      </div>
    </div>
  </div></section>

  <!-- OUTCOMES — what parents actually care about -->
  <section class="par-section"><div class="mw">
    <SectionHeader title="What Students Leave With" color="violet" />
    <div class="outcomes-grid bordered-grid">
      <div class="outcome">
        <div class="outcome-num">1</div>
        <h3>A Portfolio of Real Work</h3>
        <p>Not a participation trophy. Prototypes, business models, campaign strategies — work they built themselves that they can show to colleges, employers, or anyone who asks "what did you do this summer?"</p>
      </div>
      <div class="outcome">
        <div class="outcome-num">2</div>
        <h3>Confidence That Comes From Being Taken Seriously</h3>
        <p>When professionals and executives take your ideas seriously, it changes how you see yourself. Parents tell us this is the change they notice most.</p>
      </div>
      <div class="outcome">
        <div class="outcome-num">3</div>
        <h3>Skills That Transfer Everywhere</h3>
        <p>Judgment, communication, collaboration, creative problem-solving — the human skills that matter most as technology accelerates. These don't come from a textbook.</p>
      </div>
      <div class="outcome">
        <div class="outcome-num">4</div>
        <h3>A Global Network</h3>
        <p>Friends and collaborators from different countries and cultures, connected by a shared experience of doing real work together. The network continues long after the program ends.</p>
      </div>
    </div>
  </div></section>

  <!-- ANOTHER PARENT QUOTE -->
  <Quote text="We were not expecting this level of rigor for this age. They were structured and so innovative. This has to be because of the methodology." attribution="Corporate Partner Executive" />

  <!-- COST — total transparency -->
  <section class="par-section"><div class="mw">
    <SectionHeader title="Cost & Financial Aid" color="green" />
    <div class="par-prose">
      <p><span class="lead">We believe cost should never be the reason a qualified student can't participate.</span></p>
      <p>Program tuition covers all sessions, materials, facilitation, daily lunch, city activities, and alumni network access. Housing is separate and optional — arranged through vetted partners at each location. Day-student pricing is available for families who prefer to arrange their own accommodation.</p>
      <p>Financial aid is need-based and applied for during the enrollment process — no separate application. Both tuition and housing support are available. Aid recipients participate fully alongside all other students with no distinction.</p>
      <p>Full cost details are provided upon acceptance. If you have questions about affordability before applying, email us directly — we'll give you a straight answer.</p>
    </div>
  </div></section>

  <!-- FAQ — parent-specific questions -->
  <section class="par-faq"><div class="par-faq-inner">
    <SectionHeader title="Common Questions from Parents" color="blue" />
    <div class="faq-item"><div class="faq-q">What ages is this designed for?</div><div class="faq-a"><span class="lead">High school students ages 14–19.</span> The NYC program at Columbia admits students from rising 9th graders through graduated seniors. International programs admit rising 10th graders and older.</div></div>
    <div class="faq-item"><div class="faq-q">Is this academically rigorous or more of a summer camp?</div><div class="faq-a"><span class="lead">It's rigorous — but not in the way school is.</span> Students don't sit exams. They build things, present to real executives, and get honest feedback. The methodology is adapted from an MBA-style innovation framework used by Fortune 500 companies. The rigor comes from the work being real.</div></div>
    <div class="faq-item"><div class="faq-q">Will this help with college applications?</div><div class="faq-a"><span class="lead">Yes — but not because of the name on a résumé.</span> Students leave with a portfolio of real work, a compelling story about initiative and growth, and the ability to articulate what they learned. Admissions officers notice when a student can speak with genuine depth about an experience.</div></div>
    <div class="faq-item"><div class="faq-q">How are teams formed?</div><div class="faq-a"><span class="lead">Deliberately.</span> As part of the application, students share their work styles and preferences. We use this to build diverse, complementary teams — mixing strengths, backgrounds, and perspectives.</div></div>
    <div class="faq-item"><div class="faq-q">What if my child has never done anything like this before?</div><div class="faq-a"><span class="lead">Good — that's who this is for.</span> We're looking for curiosity and initiative, not experience. The program is designed to meet students where they are. Many of our strongest alumni had never built a business model or run a campaign before walking in on day one.</div></div>
    <div class="faq-item last"><div class="faq-q">Can I talk to someone before deciding?</div><div class="faq-a"><span class="lead">Absolutely.</span> Email <strong>hello@hudsonlabventures.com</strong> or call us. You'll speak with a real person — usually Cate or a member of our team — who can answer your specific questions. We encourage it.</div></div>
  </div></section>

  <!-- CTA — measured, not salesy -->
  <section class="par-cta"><div class="mw par-cta-inner">
    <div>
      <h2>Ready to Learn More?</h2>
      <p>Start with an application — it takes 15 minutes and there's no commitment. Or reach out directly. We're happy to talk.</p>
    </div>
    <div class="par-cta-btns">
      <a href="/admissions" class="btn-dark"><ArrowSquare /> Start an Application</a>
      <a href="mailto:hello@hudsonlabventures.com" class="btn-outline">Email Us</a>
    </div>
  </div></section>

</Base>

<style>
  .par-hero{padding:160px 80px 80px;max-width:1200px;margin:0 auto;}
  .par-label{font-family:'Barlow Semi Condensed',sans-serif;font-size:13px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--violet);margin-bottom:24px;display:flex;align-items:center;gap:12px;}
  .dot{width:8px;height:8px;background:var(--violet);display:inline-block;}
  .par-hero h1{font-size:44px;font-weight:600;line-height:1.12;color:var(--navy);max-width:620px;margin-bottom:32px;}
  .par-hero-text{max-width:600px;}
  .par-hero-text p{font-size:18px;line-height:1.7;color:var(--text-mid);margin-bottom:16px;}

  /* Sections */
  .par-section{padding:80px 0;border-top:1px solid var(--border);}
  .par-section :global(.section-header){margin-bottom:32px;}
  .par-prose{max-width:640px;}
  .par-prose p{font-size:17px;line-height:1.7;color:var(--text-mid);margin-bottom:16px;}

  /* Safety grid */
  .safety-grid{display:grid;grid-template-columns:1fr 1fr;}
  .safety-item{padding:36px 32px;}
  .safety-item h3{font-size:18px;font-weight:600;color:var(--navy);margin-bottom:8px;}
  .safety-item p{font-size:15px;line-height:1.6;color:var(--text-mid);}

  /* Outcomes */
  .outcomes-grid{display:grid;grid-template-columns:1fr 1fr;margin-top:32px;}
  .outcome{padding:36px 32px;}
  .outcome-num{font-size:32px;font-weight:600;color:var(--border);line-height:1;margin-bottom:12px;}
  .outcome h3{font-size:18px;font-weight:600;color:var(--navy);margin-bottom:8px;}
  .outcome p{font-size:15px;line-height:1.6;color:var(--text-mid);}

  /* FAQ */
  .par-faq{border-top:1px solid var(--border);padding:80px 0;}
  .par-faq-inner{max-width:780px;margin:0 auto;padding:0 40px;}
  .par-faq-inner :global(.section-header){margin-bottom:48px;}
  .faq-item{border-top:1px solid var(--border);padding:28px 0;}
  .faq-item.last{border-bottom:1px solid var(--border);}
  .faq-q{font-size:18px;font-weight:600;color:var(--navy);margin-bottom:10px;}
  .faq-a{font-size:16px;line-height:1.6;color:var(--text-mid);max-width:600px;}

  /* CTA */
  .par-cta{border-top:1px solid var(--border);padding:80px 0;}
  .par-cta-inner{display:flex;justify-content:space-between;align-items:center;}
  .par-cta h2{font-size:32px;font-weight:600;color:var(--navy);margin-bottom:8px;}
  .par-cta p{font-size:17px;color:var(--text-mid);max-width:420px;}
  .par-cta-btns{display:flex;gap:16px;}

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .par-hero{padding:120px 24px 60px;}
    .par-hero h1{font-size:32px;}
    .par-hero-text p{font-size:16px;}
    .par-section{padding:60px 0;}
    .par-section .mw{padding:0 24px;}
    .par-prose p{font-size:16px;}
    .safety-grid, .outcomes-grid{grid-template-columns:1fr;}
    .par-faq{padding:60px 0;}
    .par-faq-inner{padding:0 24px;}
    .faq-q{font-size:16px;}
    .par-cta{padding:60px 0;}
    .par-cta .mw{padding:0 24px;}
    .par-cta-inner{flex-direction:column;gap:24px;text-align:center;align-items:center;}
    .par-cta h2{font-size:26px;}
    .par-cta-btns{flex-direction:column;width:100%;}
    .par-cta-btns a{text-align:center;}
  }
</style>
