---
import Base from '../layouts/Base.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Quote from '../components/Quote.astro';
import ArrowSquare from '../components/ArrowSquare.astro';
---

<Base title="For Parents" navVariant="light" navActive="parents">

  <!-- HERO — split with photo -->
  <section class="par-hero">
    <div class="par-hero-text">
      <div class="par-label"><span class="dot"></span> For Parents & Families</div>
      <h1>The Questions You're Asking Are the Right Ones</h1>
      <p><span class="lead">You're wondering if this is real, if it's safe, and if it's worth the investment.</span> We'd be worried if you weren't. This page is for you — not a pitch, just the information you need to make a confident decision.</p>
    </div>
    <div class="par-hero-photo">
      <div class="edge" style="background:var(--violet);"></div>
      <span class="photo-placeholder">Parent and student at program event — candid, warm</span>
    </div>
  </section>

  <!-- WHAT YOUR CHILD WILL DO — with photo -->
  <section class="par-what"><div class="mw">
    <SectionHeader title="What Your Child Will Actually Do" color="coral" />
    <div class="what-layout">
      <div class="what-text">
        <p><span class="lead">Every day from 9:00 to 17:00, students work in small teams on a real challenge.</span> Not a simulation — an actual problem that a real company needs solved. They research, prototype, test, and present their work to executives who take it seriously.</p>
        <p>Students choose one of three tracks. They work within their track but learn from all three through daily cross-track critiques. By the end, they have tangible work they can show anyone.</p>
      </div>
      <div class="what-tracks">
        <div class="what-track"><svg viewBox="0 0 24 24" stroke="var(--coral)" width="20" height="20" class="c-icon"><rect x="3" y="3" width="18" height="18"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="9" x2="9" y2="21"/></svg><div><strong>Product</strong><span>Design & Build</span></div></div>
        <div class="what-track"><svg viewBox="0 0 24 24" stroke="var(--green)" width="20" height="20" class="c-icon"><path d="M4 20 L12 4 L20 20 Z"/><line x1="8" y1="14" x2="16" y2="14"/></svg><div><strong>Business</strong><span>Model & Validate</span></div></div>
        <div class="what-track"><svg viewBox="0 0 24 24" stroke="var(--blue)" width="20" height="20" class="c-icon"><polyline points="4 17 10 11 14 15 20 9"/><line x1="15" y1="9" x2="20" y2="9"/><line x1="20" y1="9" x2="20" y2="14"/></svg><div><strong>Go-to-Market</strong><span>Launch & Grow</span></div></div>
      </div>
    </div>
  </div></section>

  <!-- PHOTO BREAK -->
  <div class="photo-full"><span class="photo-placeholder">Students presenting to executives — the "adults take you seriously" moment</span></div>

  <!-- PARENT QUOTE -->
  <Quote text="When it came time for college applications, my child's experience at Hudson Lab Ventures was a true point of distinction. But honestly, the bigger change was in how she carried herself afterward." attribution="Parent, NYC 2024" />

  <!-- SAFETY & SUPERVISION -->
  <section class="par-section"><div class="mw">
    <SectionHeader title="Safety & Supervision" color="navy" />
    <p class="par-intro"><span class="lead">We take duty of care seriously. Here's exactly how it works.</span></p>
    <div class="safety-grid bordered-grid">
      <div class="safety-item">
        <div class="s-icon"><svg viewBox="0 0 24 24" stroke="var(--navy)" width="22" height="22"><circle cx="12" cy="12" r="9"/><line x1="12" y1="7" x2="12" y2="12"/><line x1="12" y1="12" x2="16" y2="14"/></svg></div>
        <h3>Program Hours</h3>
        <p>Adult facilitators present 9:00–17:00 daily. Small student-to-facilitator ratio. All activities supervised.</p>
      </div>
      <div class="safety-item">
        <div class="s-icon"><svg viewBox="0 0 24 24" stroke="var(--navy)" width="22" height="22"><rect x="3" y="6" width="18" height="14"/><line x1="3" y1="10" x2="21" y2="10"/><path d="M8 6 L8 3 M16 6 L16 3"/></svg></div>
        <h3>Housing</h3>
        <p>NYC: Columbia University dorms with 24/7 security and Resident Advisors. International: vetted local partners with on-site staff. Day-student option at every location.</p>
      </div>
      <div class="safety-item">
        <div class="s-icon"><svg viewBox="0 0 24 24" stroke="var(--navy)" width="22" height="22"><path d="M12 3 L20 7.5 L20 16.5 L12 21 L4 16.5 L4 7.5 Z"/></svg></div>
        <h3>Evenings</h3>
        <p>HLV activities are supervised. Independent outings use a buddy system with check-ins. Curfews enforced at all residential programs.</p>
      </div>
      <div class="safety-item">
        <div class="s-icon"><svg viewBox="0 0 24 24" stroke="var(--navy)" width="22" height="22"><rect x="4" y="4" width="16" height="16"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="12" y1="4" x2="12" y2="20"/></svg></div>
        <h3>Communication</h3>
        <p>Welcome packet with emergency contacts before the program. Phone and email access throughout. We respond like humans, not form letters.</p>
      </div>
    </div>
  </div></section>

  <!-- OUTCOMES — with icons -->
  <section class="par-section outcomes-section"><div class="mw">
    <SectionHeader title="What Students Leave With" color="violet" />
    <div class="outcomes-row">
      <div class="outcome-card">
        <div class="o-icon" style="background:rgba(228,108,65,0.08);"><svg viewBox="0 0 24 24" stroke="var(--coral)" width="22" height="22"><rect x="3" y="3" width="18" height="18"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="3" x2="9" y2="21"/></svg></div>
        <h3>A Portfolio of Real Work</h3>
        <p>Prototypes, business models, campaign strategies — work they built that they can show colleges, employers, or anyone who asks.</p>
      </div>
      <div class="outcome-card">
        <div class="o-icon" style="background:rgba(123,79,219,0.08);"><svg viewBox="0 0 24 24" stroke="var(--violet)" width="22" height="22"><circle cx="12" cy="8" r="4"/><path d="M4 20 C4 16 8 14 12 14 C16 14 20 16 20 20"/></svg></div>
        <h3>Confidence From Being Taken Seriously</h3>
        <p>When executives take your ideas seriously, it changes how you see yourself. Parents notice this more than anything.</p>
      </div>
      <div class="outcome-card">
        <div class="o-icon" style="background:rgba(59,125,216,0.08);"><svg viewBox="0 0 24 24" stroke="var(--blue)" width="22" height="22"><polyline points="4 12 9 17 20 6"/></svg></div>
        <h3>Skills AI Won't Replace</h3>
        <p>Judgment, communication, collaboration, creative problem-solving — the human skills that matter most as technology accelerates.</p>
      </div>
      <div class="outcome-card">
        <div class="o-icon" style="background:rgba(52,199,89,0.08);"><svg viewBox="0 0 24 24" stroke="var(--green)" width="22" height="22"><circle cx="8" cy="12" r="4"/><circle cx="16" cy="12" r="4"/></svg></div>
        <h3>A Global Network</h3>
        <p>Friends from different countries, connected by real work. The network grows every cohort — and opens doors for years.</p>
      </div>
    </div>
  </div></section>

  <!-- PHOTO PAIR -->
  <div class="photo-pair">
    <div class="photo-pair-item"><span class="photo-placeholder">Students collaborating in studio</span></div>
    <div class="photo-pair-item"><span class="photo-placeholder">City exploration / cultural moment</span></div>
  </div>

  <!-- EXEC QUOTE -->
  <Quote variant="navy" text="The quality of the final presentations is what I would expect from a top tier consulting firm. The students were standing there pitching to real executives and owning the room." attribution="Corporate Partner Executive" accentColors={['violet', 'pop']} />

  <!-- COST -->
  <section class="par-section"><div class="mw">
    <SectionHeader title="Cost & Financial Aid" color="green" />
    <div class="cost-prose">
      <p><span class="lead">We believe cost should never be the reason a qualified student can't participate.</span></p>
      <p>Tuition covers all sessions, materials, facilitation, daily lunch, city activities, and alumni network access. Housing is separate and optional. Day-student pricing available at every location.</p>
      <p>Financial aid is need-based — applied for during enrollment, no separate application. Both tuition and housing support available. Full cost details provided upon acceptance.</p>
    </div>
    <div class="cost-note">
      <span class="lead">Questions about affordability before applying?</span> Email us directly at <strong>hello@hudsonlabventures.com</strong> — we'll give you a straight answer.
    </div>
  </div></section>

  <!-- FAQ -->
  <section class="par-faq"><div class="par-faq-inner">
    <SectionHeader title="Common Questions" color="blue" />
    <div class="faq-item"><div class="faq-q">What ages is this designed for?</div><div class="faq-a"><span class="lead">High school students ages 14–19.</span> NYC at Columbia admits rising 9th graders through graduated seniors. International programs: rising 10th graders and older.</div></div>
    <div class="faq-item"><div class="faq-q">Is this academically rigorous or more of a summer camp?</div><div class="faq-a"><span class="lead">Rigorous — but not in the way school is.</span> The methodology is adapted from an MBA-style framework used by Fortune 500 companies. The rigor comes from the work being real, not from tests.</div></div>
    <div class="faq-item"><div class="faq-q">Will this help with college applications?</div><div class="faq-a"><span class="lead">Yes — because the experience is genuine.</span> Students leave with real work, a compelling growth story, and the ability to articulate what they learned with depth that admissions officers notice.</div></div>
    <div class="faq-item"><div class="faq-q">What if my child has never done anything like this?</div><div class="faq-a"><span class="lead">That's who this is for.</span> We're looking for curiosity and initiative, not experience. Many of our strongest alumni walked in on day one having never built a business model or run a campaign.</div></div>
    <div class="faq-item last"><div class="faq-q">Can I talk to someone before deciding?</div><div class="faq-a"><span class="lead">Please do.</span> Email <strong>hello@hudsonlabventures.com</strong> or call us. You'll speak with Cate or a team member who can answer your specific questions.</div></div>
  </div></section>

  <!-- CTA -->
  <section class="par-cta"><div class="mw par-cta-inner">
    <div><h2>Ready to Learn More?</h2><p>Start with an application — 15 minutes, no commitment. Or reach out directly.</p></div>
    <div class="par-cta-btns">
      <a href="/admissions" class="btn-dark"><ArrowSquare /> Start an Application</a>
      <a href="mailto:hello@hudsonlabventures.com" class="btn-outline">Email Us</a>
    </div>
  </div></section>

</Base>

<style>
  /* HERO — split */
  .par-hero{display:grid;grid-template-columns:1fr 1fr;min-height:80vh;padding-top:56px;}
  .par-hero-text{padding:120px 80px 80px;display:flex;flex-direction:column;justify-content:center;max-width:560px;margin-left:auto;}
  .par-label{font-family:'Barlow Semi Condensed',sans-serif;font-size:13px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--violet);margin-bottom:24px;display:flex;align-items:center;gap:12px;}
  .dot{width:8px;height:8px;background:var(--violet);display:inline-block;}
  .par-hero h1{font-size:40px;font-weight:600;line-height:1.12;color:var(--navy);margin-bottom:24px;}
  .par-hero-text p{font-size:17px;line-height:1.7;color:var(--text-mid);}
  .par-hero-photo{position:relative;display:flex;align-items:center;justify-content:center;background:var(--bg-subtle);}
  .par-hero-photo .edge{position:absolute;left:0;top:0;bottom:0;width:6px;}

  /* WHAT — text + track list */
  .par-what{padding:100px 0;border-top:1px solid var(--border);}
  .par-what :global(.section-header){margin-bottom:32px;}
  .what-layout{display:grid;grid-template-columns:1fr 280px;gap:64px;align-items:start;}
  .what-text p{font-size:17px;line-height:1.7;color:var(--text-mid);margin-bottom:16px;}
  .what-tracks{display:flex;flex-direction:column;gap:0;border:1px solid var(--border);border-radius:2px;}
  .what-track{display:flex;align-items:center;gap:16px;padding:20px;border-bottom:1px solid var(--border);}
  .what-track:last-child{border-bottom:none;}
  .what-track svg{flex-shrink:0;stroke-width:1.5;stroke-linecap:square;stroke-linejoin:miter;fill:none;}
  .what-track strong{display:block;font-size:15px;font-weight:600;color:var(--navy);}
  .what-track span{font-size:13px;color:var(--text-light);}

  /* Photo sections */
  .photo-full{width:100%;height:400px;background:var(--bg-subtle);display:flex;align-items:center;justify-content:center;}
  .photo-full span{border:1px solid var(--border);padding:16px 32px;}
  .photo-pair{display:grid;grid-template-columns:2fr 1fr;gap:1px;height:360px;}
  .photo-pair-item{display:flex;align-items:center;justify-content:center;background:var(--bg-subtle);}
  .photo-pair-item:nth-child(2){background:#e2e0dc;}

  /* Sections */
  .par-section{padding:80px 0;border-top:1px solid var(--border);}
  .par-section :global(.section-header){margin-bottom:32px;}
  .par-intro{font-size:17px;line-height:1.7;color:var(--text-mid);margin-bottom:40px;max-width:480px;}

  /* Safety grid */
  .safety-grid{display:grid;grid-template-columns:1fr 1fr;}
  .safety-item{padding:32px;}
  .s-icon{width:44px;height:44px;display:flex;align-items:center;justify-content:center;margin-bottom:16px;}
  .s-icon svg{stroke-width:1.5;stroke-linecap:square;stroke-linejoin:miter;fill:none;}
  .safety-item h3{font-size:17px;font-weight:600;color:var(--navy);margin-bottom:8px;}
  .safety-item p{font-size:15px;line-height:1.6;color:var(--text-mid);}

  /* Outcomes */
  .outcomes-section :global(.section-header){margin-bottom:40px;}
  .outcomes-row{display:grid;grid-template-columns:repeat(4,1fr);gap:0;border-top:1px solid var(--border);border-left:1px solid var(--border);}
  .outcome-card{padding:32px 28px;border-right:1px solid var(--border);border-bottom:1px solid var(--border);}
  .o-icon{width:44px;height:44px;display:flex;align-items:center;justify-content:center;margin-bottom:16px;border-radius:0;}
  .o-icon svg{stroke-width:1.5;stroke-linecap:square;stroke-linejoin:miter;fill:none;}
  .outcome-card h3{font-size:16px;font-weight:600;color:var(--navy);margin-bottom:8px;}
  .outcome-card p{font-size:14px;line-height:1.55;color:var(--text-mid);}

  /* Cost */
  .cost-prose{max-width:600px;}
  .cost-prose p{font-size:17px;line-height:1.7;color:var(--text-mid);margin-bottom:16px;}
  .cost-note{margin-top:32px;padding:28px 32px;background:rgba(52,199,89,0.04);border-left:4px solid var(--green);font-size:16px;line-height:1.6;color:var(--text-mid);max-width:600px;}

  /* FAQ */
  .par-faq{border-top:1px solid var(--border);padding:80px 0;}
  .par-faq-inner{max-width:780px;margin:0 auto;padding:0 40px;}
  .par-faq-inner :global(.section-header){margin-bottom:48px;}
  .faq-item{border-top:1px solid var(--border);padding:28px 0;}
  .faq-item.last{border-bottom:1px solid var(--border);}
  .faq-q{font-size:18px;font-weight:600;color:var(--navy);margin-bottom:10px;}
  .faq-a{font-size:16px;line-height:1.6;color:var(--text-mid);max-width:600px;}

  /* CTA */
  .par-cta{border-top:1px solid var(--border);padding:80px 0;}
  .par-cta-inner{display:flex;justify-content:space-between;align-items:center;}
  .par-cta h2{font-size:32px;font-weight:600;color:var(--navy);margin-bottom:8px;}
  .par-cta p{font-size:17px;color:var(--text-mid);max-width:420px;}
  .par-cta-btns{display:flex;gap:16px;}

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .par-hero{grid-template-columns:1fr;min-height:auto;}
    .par-hero-text{padding:100px 24px 40px;max-width:100%;margin:0;}
    .par-hero h1{font-size:30px;}
    .par-hero-photo{height:280px;}
    .par-what{padding:60px 0;}
    .par-what .mw{padding:0 24px;}
    .what-layout{grid-template-columns:1fr;gap:32px;}
    .par-section .mw{padding:0 24px;}
    .photo-full{height:240px;}
    .photo-pair{grid-template-columns:1fr;height:auto;}
    .photo-pair-item{height:200px;}
    .safety-grid{grid-template-columns:1fr;}
    .outcomes-row{grid-template-columns:1fr 1fr;}
    .par-faq{padding:60px 0;}
    .par-faq-inner{padding:0 24px;}
    .faq-q{font-size:16px;}
    .par-cta{padding:60px 0;}
    .par-cta .mw{padding:0 24px;}
    .par-cta-inner{flex-direction:column;gap:24px;text-align:center;align-items:center;}
    .par-cta h2{font-size:26px;}
    .par-cta-btns{flex-direction:column;width:100%;}
    .par-cta-btns a{text-align:center;}
  }
  @media (max-width: 480px) {
    .outcomes-row{grid-template-columns:1fr;}
  }
</style>
