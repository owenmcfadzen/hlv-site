---
// Private design-system reference. NOT linked from nav.
// Patterns marked [EXTRACT →] are candidates to promote to components.
import Base from '../../layouts/Base.astro';
import ArrowSquare from '../../components/ArrowSquare.astro';
import A5cBar from '../../components/A5cBar.astro';

const palette = [
  { name: 'violet-600', hex: '#7B4FDB', css: '--violet', role: 'Primary identity · cross-track' },
  { name: 'blue-600',   hex: '#3B7DD8', css: '--blue',   role: 'CTA, links · GTM track' },
  { name: 'coral-600',  hex: '#E46C41', css: '--coral',  role: 'Energy · Product track' },
  { name: 'pop-400',    hex: '#FFD43B', css: '--pop',    role: 'Highlights (dark text only)' },
  { name: 'green-400',  hex: '#34C759', css: '--green',  role: 'Business track' },
  { name: 'navy-800',   hex: '#182D53', css: '--navy',   role: 'Text, dark bg, authority' },
];
---
<Base title="Lookbook" description="Private design reference">
  <div class="lookbook">

    <header class="lb-head">
      <div class="lb-mark"><ArrowSquare /></div>
      <div>
        <div class="lb-crumb">HLV · internal</div>
        <h1>Design Lookbook</h1>
        <p class="lb-sub">Every component variation, plus exploratory patterns. Not a public page. Scroll to browse; copy what earns its keep. Decisions and assumptions at the bottom.</p>
      </div>
    </header>

    <!-- §1.1 HERO VARIATIONS -->
    <section class="lb-section">
      <div class="lb-section-head">
        <span class="lb-tick" style="background: var(--violet)"></span>
        <h2>1.1 Hero Variations</h2>
        <span class="lb-note">Six patterns. Current live: typographic, split, dark-highlighted. New: full-bleed photo, centered, video placeholder.</span>
      </div>

      <div class="lb-variant">
        <div class="lb-label">A · Typographic hero — size ladder (current: landing, alumni)</div>
        <div class="hero-typo">
          <div class="hero-typo-mark"><span style="background: var(--violet)"></span></div>
          <h1 style="font-size: 72px;">Summer innovation, in four cities.</h1>
          <p class="lead">A two-week program for high-school students working on real business challenges.</p>
          <div class="hero-cta"><a class="btn-dark" href="#">Apply <ArrowSquare size="small" /></a></div>
        </div>
        <div class="hero-typo">
          <div class="hero-typo-mark"><span style="background: var(--coral)"></span></div>
          <h1 style="font-size: 56px;">Same hero, tighter scale.</h1>
          <p class="lead">56px reads stronger on 13" screens. Candidate default for lower pages.</p>
        </div>
      </div>

      <div class="lb-variant">
        <div class="lb-label">B · Split hero — edge-bar color rotation (current: admissions, parents)</div>
        <div class="split-demo" style="--edge: var(--violet)">
          <div class="split-text">
            <div class="split-cap"><span class="dot"></span> Admissions</div>
            <h2>A two-week program for students building something real.</h2>
            <p>Not a camp. Not a lecture series. A working studio.</p>
          </div>
          <div class="split-photo"><div class="split-edge"></div><span class="photo-placeholder">Photo · workshop</span></div>
        </div>
        <div class="split-demo split-flip" style="--edge: var(--coral)">
          <div class="split-photo"><div class="split-edge"></div><span class="photo-placeholder">Photo · parents</span></div>
          <div class="split-text">
            <div class="split-cap"><span class="dot" style="background: var(--coral)"></span> Parents</div>
            <h2>Flipped split — coral edge, photo left.</h2>
            <p>Alternating direction helps a long scroll feel edited.</p>
          </div>
        </div>
        <div class="split-demo" style="--edge: transparent">
          <div class="split-text">
            <div class="split-cap" style="color: var(--blue)"><span class="dot" style="background: var(--blue)"></span> Program</div>
            <h2>Split without edge bar — cleaner, quieter.</h2>
            <p>Useful when the A5c bar sits close by.</p>
          </div>
          <div class="split-photo"><span class="photo-placeholder">Photo · studio</span></div>
        </div>
      </div>

      <div class="lb-variant">
        <div class="lb-label">C · Dark hero — highlighted-text sequences (current: city programs)</div>
        <div class="dark-hero">
          <div class="hl-stack">
            <span class="hl-block" style="background: var(--violet)">Build something</span>
            <span class="hl-block" style="background: var(--pop); color: var(--navy); margin-left: 32px;">real</span>
            <span class="hl-block" style="background: var(--navy); margin-left: 0;">in two weeks.</span>
          </div>
          <p class="dark-hero-cap">violet → pop → navy · current signature</p>
        </div>
        <div class="dark-hero">
          <div class="hl-stack">
            <span class="hl-block" style="background: var(--coral)">Ship working</span>
            <span class="hl-block" style="background: var(--pop); color: var(--navy); margin-left: 24px;">products</span>
            <span class="hl-block" style="background: var(--navy); margin-left: 8px;">with real users.</span>
          </div>
          <p class="dark-hero-cap">coral → pop → navy · warmer, energizing</p>
        </div>
        <div class="dark-hero">
          <div class="hl-stack">
            <span class="hl-block" style="background: var(--blue)">Serious work</span>
            <span class="hl-block" style="background: var(--pop); color: var(--navy); margin-left: 40px;">on serious</span>
            <span class="hl-block" style="background: var(--navy); margin-left: 16px;">problems.</span>
          </div>
          <p class="dark-hero-cap">blue → pop → navy · cooler, credible (GTM-forward)</p>
        </div>
      </div>

      <div class="lb-variant">
        <div class="lb-label">D · Full-bleed photo hero with overlay — <em>new pattern</em> [EXTRACT → HeroFullBleed.astro]</div>
        <div class="fullbleed-hero">
          <div class="fb-photo"><span class="photo-placeholder on-dark">Full-bleed hero photo</span></div>
          <div class="fb-overlay">
            <div class="fb-cap"><span class="dot" style="background: var(--pop)"></span> New York</div>
            <h2>Two weeks on the Lower East Side.</h2>
            <p>Overlay lower-left, 72px padding. Gradient from bottom for honest contrast.</p>
          </div>
        </div>
      </div>

      <div class="lb-variant">
        <div class="lb-label">E · Centered hero — minimal [EXTRACT → HeroCentered.astro for /about, /mission]</div>
        <div class="centered-hero">
          <div class="ch-mark"><span style="background: var(--violet)"></span><span style="background: var(--pop)"></span></div>
          <h2>The quietest way to introduce the work.</h2>
          <p>One mark. One sentence. Two lines of context. Nothing else.</p>
        </div>
      </div>

      <div class="lb-variant">
        <div class="lb-label">F · Video placeholder hero — dark with play affordance</div>
        <div class="video-hero">
          <button class="video-play" aria-label="Play">
            <svg viewBox="0 0 24 24" width="22" height="22"><polygon points="7,4 20,12 7,20" fill="var(--navy)"/></svg>
          </button>
          <div class="video-cap">A day in Lisbon · 2:14</div>
        </div>
      </div>
    </section>

    <!-- §1.2 GEOMETRIC PATTERNS -->
    <section class="lb-section">
      <div class="lb-section-head">
        <span class="lb-tick" style="background: var(--blue)"></span>
        <h2>1.2 Geometric Patterns & Visual Elements</h2>
        <span class="lb-note">Arrow-square explorations, vertical A5c, mark variants, diagonals, edge bars, gradients, corner accents.</span>
      </div>

      <div class="lb-variant">
        <div class="lb-label">A · Arrow-square scale ladder (24 / 36 / 48 / 64)</div>
        <div class="sq-ladder">
          <span class="arrow-sq-demo" style="--s: 24px"><span class="arrow-sq-in">→</span><em>24px · inline</em></span>
          <span class="arrow-sq-demo" style="--s: 36px"><span class="arrow-sq-in">→</span><em>36px · standard</em></span>
          <span class="arrow-sq-demo" style="--s: 48px"><span class="arrow-sq-in">→</span><em>48px · feature</em></span>
          <span class="arrow-sq-demo" style="--s: 64px"><span class="arrow-sq-in">→</span><em>64px · hero anchor</em></span>
        </div>
        <p class="lb-caption">Keep arrow at ~40% of the square width — don't scale linearly.</p>
      </div>

      <div class="lb-variant">
        <div class="lb-label">B · Arrow-square as repeating texture — <em>exploratory</em></div>
        <div class="sq-texture">
          <div class="sq-texture-grid"></div>
          <div class="sq-texture-cap">Tile at 36px with 12px gap. 10% opacity on dark, 25% on warm white. Must reinforce the mark, not decorate.</div>
        </div>
      </div>

      <div class="lb-variant">
        <div class="lb-label">C · A5c bar as vertical element — <em>exploratory</em></div>
        <div class="a5c-vertical-wrap">
          <div class="a5c-vertical">
            <div style="flex: 6; background: var(--violet)"></div>
            <div style="flex: 5; background: var(--blue)"></div>
            <div style="flex: 4; background: var(--coral)"></div>
            <div style="flex: 3; background: var(--pop)"></div>
            <div style="flex: 2; background: var(--green)"></div>
            <div style="flex: 2; background: var(--navy)"></div>
          </div>
          <div class="a5c-vertical-body">
            <p class="lead">Vertical A5c works as a left-edge anchor on long-form pages.</p>
            <p>4px wide, full page height, fixed position. Use once per page.</p>
          </div>
        </div>
      </div>

      <div class="lb-variant">
        <div class="lb-label">D · Section mark — shape & size variations</div>
        <div class="mark-grid">
          <div class="mark-cell"><div class="sm-bar-lg" style="background: var(--violet)"></div><em>6 × 48 · current</em></div>
          <div class="mark-cell"><div class="sm-bar-sm" style="background: var(--violet)"></div><em>6 × 24 · compact</em></div>
          <div class="mark-cell"><div class="sm-dot" style="background: var(--violet)"></div><em>dot · quiet pages</em></div>
          <div class="mark-cell"><div class="sm-sq" style="background: var(--violet)"></div><em>square · structural</em></div>
          <div class="mark-cell"><div class="sm-stack"><div style="background: var(--violet)"></div><div style="background: var(--pop)"></div></div><em>double bar</em></div>
          <div class="mark-cell"><div class="sm-sq" style="background: var(--pop); color: var(--navy); display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700;">A</div><em>letter square</em></div>
        </div>
      </div>

      <div class="lb-variant">
        <div class="lb-label">E · Diagonal cut section — 2.5° <em>exploratory</em></div>
        <div class="diag-wrap">
          <div class="diag-top"></div>
          <div class="diag-body"><p>Useful only between warm-white and dark. Never light-on-light.</p></div>
          <div class="diag-bottom"></div>
        </div>
      </div>

      <div class="lb-variant">
        <div class="lb-label">F · Edge-bar bordered cards [EXTRACT → EdgeCard.astro]</div>
        <div class="edge-card-row">
          <div class="edge-card" style="--edge: var(--violet)"><div class="ec-edge"></div><div><strong>Program</strong><p>4px left edge on warm white.</p></div></div>
          <div class="edge-card" style="--edge: var(--coral)"><div class="ec-edge"></div><div><strong>Product</strong><p>Matches track color.</p></div></div>
          <div class="edge-card" style="--edge: var(--blue)"><div class="ec-edge"></div><div><strong>GTM</strong><p>Edge does the work.</p></div></div>
        </div>
      </div>

      <div class="lb-variant">
        <div class="lb-label">G · A5c gradient overlays — <em>exploratory</em></div>
        <div class="grad-row">
          <div class="grad-cell" style="background: linear-gradient(135deg, var(--violet), var(--navy))"><span>violet → navy</span></div>
          <div class="grad-cell" style="background: linear-gradient(135deg, var(--coral), var(--violet))"><span>coral → violet</span></div>
          <div class="grad-cell" style="background: linear-gradient(135deg, var(--blue), var(--navy))"><span>blue → navy</span></div>
        </div>
        <p class="lb-caption">Use at ≤10% wash over photos, never as section fill.</p>
      </div>

      <div class="lb-variant">
        <div class="lb-label">H · Corner accents — arrow-square in card corners</div>
        <div class="corner-row">
          <div class="corner-card"><div class="corner-sq"></div><strong>Feature card</strong><p>Top-left square = entry point.</p></div>
          <div class="corner-card"><div class="corner-sq corner-sq-br"></div><strong>Bottom-right</strong><p>Continue / page-turn affordance.</p></div>
          <div class="corner-card corner-card-dark"><div class="corner-sq"></div><strong>On dark</strong><p>Pop snaps harder against navy.</p></div>
        </div>
      </div>
    </section>

    <!-- §1.3 SECTION PATTERNS -->
    <section class="lb-section">
      <div class="lb-section-head">
        <span class="lb-tick" style="background: var(--coral)"></span>
        <h2>1.3 Section Pattern Variations</h2>
        <span class="lb-note">Grids, stats, quotes, cards, timeline, photos, CTAs — 2–4 treatments each.</span>
      </div>

      <div class="lb-variant">
        <div class="lb-label">A · Bordered grid — layout variations</div>
        <div class="sub-label">2 × 2 (current)</div>
        <div class="bordered-grid grid-2x2">
          <div class="bg-cell"><strong>Outcome</strong><p>Working product.</p></div>
          <div class="bg-cell"><strong>Mentorship</strong><p>Real operators.</p></div>
          <div class="bg-cell"><strong>Peer cohort</strong><p>24 students, four cities.</p></div>
          <div class="bg-cell"><strong>Alumni</strong><p>Network that compounds.</p></div>
        </div>
        <div class="sub-label">4 × 1 horizontal strip</div>
        <div class="bordered-grid grid-4x1">
          <div class="bg-cell"><strong>01 Discover</strong><p>Ship a working product.</p></div>
          <div class="bg-cell"><strong>02 Build</strong><p>With operators.</p></div>
          <div class="bg-cell"><strong>03 Ship</strong><p>Four cities.</p></div>
          <div class="bg-cell"><strong>04 Reflect</strong><p>Compound network.</p></div>
        </div>
        <div class="sub-label">1 × 4 vertical stack</div>
        <div class="bordered-grid grid-1x4">
          <div class="bg-cell"><strong>Research</strong><p>Scoping with the partner.</p></div>
          <div class="bg-cell"><strong>Prototype</strong><p>Three days of build cycles.</p></div>
          <div class="bg-cell"><strong>Test</strong><p>Two days in the field.</p></div>
          <div class="bg-cell"><strong>Present</strong><p>Final demo.</p></div>
        </div>
        <div class="sub-label">Asymmetric: 1 large + 2 small</div>
        <div class="asym-grid">
          <div class="asym-lg"><strong>The core idea</strong><p>Large cell earns weight from a longer lead. Use when one point matters more than the others — not every section has a hero claim.</p></div>
          <div class="asym-sm"><strong>Supporting</strong><p>One beat.</p></div>
          <div class="asym-sm"><strong>Supporting</strong><p>One beat.</p></div>
        </div>
      </div>

      <div class="lb-variant">
        <div class="lb-label">B · Stats — four treatments</div>
        <div class="sub-label">Horizontal (current)</div>
        <div class="stats-h">
          <div><div class="stat-val">98%</div><div class="label-xs">Placement</div></div>
          <div><div class="stat-val">24</div><div class="label-xs">Students</div></div>
          <div><div class="stat-val">4</div><div class="label-xs">Cities</div></div>
          <div><div class="stat-val">14</div><div class="label-xs">Days</div></div>
          <div><div class="stat-val">12</div><div class="label-xs">Partners</div></div>
        </div>
        <div class="sub-label">Vertical sidebar</div>
        <div class="stats-v-wrap">
          <div class="stats-v">
            <div><div class="stat-val">98%</div><div class="label-xs">Placement</div></div>
            <div><div class="stat-val">24</div><div class="label-xs">Students</div></div>
            <div><div class="stat-val">4</div><div class="label-xs">Cities</div></div>
          </div>
          <div class="stats-v-body"><p>Sidebar stats pair with long-read copy. Max 3 numbers.</p></div>
        </div>
        <div class="sub-label">Circular badges (illustrative only — breaks 2px radius rule)</div>
        <div class="stats-circle">
          <div class="stat-circ" style="border-color: var(--violet); color: var(--violet)">98%</div>
          <div class="stat-circ" style="border-color: var(--coral); color: var(--coral)">24</div>
          <div class="stat-circ" style="border-color: var(--blue); color: var(--blue)">4</div>
          <div class="stat-circ" style="border-color: var(--green); color: var(--green)">14</div>
        </div>
        <div class="sub-label">Big number + stacked label</div>
        <div class="stats-big">
          <div><div class="stat-big-val">98<span>%</span></div><div class="stat-big-sub">Placement in top programs or internships within 12 months.</div></div>
          <div><div class="stat-big-val">24</div><div class="stat-big-sub">Students per cohort — small on purpose.</div></div>
        </div>
      </div>

      <div class="lb-variant">
        <div class="lb-label">C · Quote — four treatments</div>
        <div class="sub-label">Warm centered (current)</div>
        <div class="quote-warm-demo">
          <div class="q-marks" style="justify-content: center; margin-bottom: 28px;">
            <span style="width: 28px; background: var(--violet); height: 4px;"></span>
            <span style="width: 16px; background: var(--pop); height: 4px;"></span>
          </div>
          <blockquote>The most useful two weeks of my high-school life — I learned how to ship something people actually used.</blockquote>
          <span class="attr">Mei L · Alumni '24</span>
        </div>
        <div class="sub-label">Pull-quote inline</div>
        <div class="pull-wrap">
          <p>Prose sits to the left. The pull-quote anchors the right half at a larger scale.</p>
          <blockquote class="pull-quote">"Small cohort, real operators, genuine work."</blockquote>
          <p>Prose resumes. Good for long-form alumni profiles.</p>
        </div>
        <div class="sub-label">Sidebar quote (narrow column)</div>
        <div class="sidebar-quote-wrap">
          <div class="sq-side">
            <div class="q-marks"><span style="width: 20px; background: var(--coral); height: 4px;"></span></div>
            <blockquote>I came in skeptical. I left with a plan.</blockquote>
            <span class="attr">Jordan R · Parent</span>
          </div>
          <div class="sq-body"><p>Column 280px wide beside body copy at 640px. Reads like an editor's pull.</p></div>
        </div>
        <div class="sub-label">Quote with speaker photo</div>
        <div class="speaker-quote">
          <div class="sq-photo"><span class="photo-placeholder">Portrait</span></div>
          <div>
            <blockquote>Watching my kid build something real changed how I think about what school is for.</blockquote>
            <span class="attr">Jordan R · Parent · New York '24</span>
          </div>
        </div>
      </div>

      <div class="lb-variant">
        <div class="lb-label">D · Card layouts</div>
        <div class="sub-label">Colored top-edge</div>
        <div class="top-edge-row">
          <div class="te-card" style="--edge: var(--violet)"><div class="te-top"></div><strong>Strategy</strong><p>Top edge = track color.</p></div>
          <div class="te-card" style="--edge: var(--coral)"><div class="te-top"></div><strong>Product</strong><p>Track-assigned cue.</p></div>
          <div class="te-card" style="--edge: var(--blue)"><div class="te-top"></div><strong>GTM</strong><p>Works in bordered-grid too.</p></div>
        </div>
        <div class="sub-label">Horizontal icon-left / text-right</div>
        <div class="horiz-row">
          <div class="h-card">
            <div class="h-icon"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="var(--navy)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18"/><path d="M3 9h18M9 3v18"/></svg></div>
            <div><strong>Structured studio days</strong><p>Mornings scoping, afternoons building.</p></div>
          </div>
          <div class="h-card">
            <div class="h-icon"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="var(--coral)" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg></div>
            <div><strong>Real delivery windows</strong><p>Two weeks. Ship date. Client review.</p></div>
          </div>
        </div>
        <div class="sub-label">Ghost number cards</div>
        <div class="ghost-row">
          <div class="g-card"><div class="g-num">01</div><strong>Scope</strong><p>Define the real problem.</p></div>
          <div class="g-card"><div class="g-num">02</div><strong>Build</strong><p>Prototype by day 5.</p></div>
          <div class="g-card"><div class="g-num">03</div><strong>Ship</strong><p>Demo to the operator.</p></div>
        </div>
        <div class="sub-label">Photo-background cards</div>
        <div class="photo-bg-row">
          <div class="pb-card"><span class="photo-placeholder on-dark">NYC</span><div class="pb-overlay"><strong>New York</strong><p>Lower East Side.</p></div></div>
          <div class="pb-card"><span class="photo-placeholder on-dark">Lisbon</span><div class="pb-overlay"><strong>Lisbon</strong><p>Ribeira studio.</p></div></div>
          <div class="pb-card"><span class="photo-placeholder on-dark">Porto</span><div class="pb-overlay"><strong>Porto</strong><p>River-side workshop.</p></div></div>
        </div>
      </div>

      <div class="lb-variant">
        <div class="lb-label">E · Timeline / process</div>
        <div class="sub-label">Numbered steps (current)</div>
        <div class="num-steps">
          <div class="ns-step"><span class="ns-n">01</span><div><strong>Apply</strong><p>30-min application.</p></div></div>
          <div class="ns-step"><span class="ns-n">02</span><div><strong>Interview</strong><p>Conversational.</p></div></div>
          <div class="ns-step"><span class="ns-n">03</span><div><strong>Accept</strong><p>10-day decision.</p></div></div>
          <div class="ns-step"><span class="ns-n">04</span><div><strong>Arrive</strong><p>Two weeks, one city.</p></div></div>
        </div>
        <div class="sub-label">Connected-dot timeline</div>
        <div class="dot-timeline">
          <div class="dt-line"></div>
          <div class="dt-step"><span class="dt-dot" style="color: var(--violet); background: var(--violet)"></span><strong>Apply</strong><p>Feb–April</p></div>
          <div class="dt-step"><span class="dt-dot" style="color: var(--coral); background: var(--coral)"></span><strong>Interview</strong><p>Rolling</p></div>
          <div class="dt-step"><span class="dt-dot" style="color: var(--blue); background: var(--blue)"></span><strong>Accept</strong><p>10 days</p></div>
          <div class="dt-step"><span class="dt-dot" style="color: var(--pop); background: var(--pop)"></span><strong>Arrive</strong><p>Jun–Aug</p></div>
        </div>
        <div class="sub-label">Horizontal stepper</div>
        <div class="stepper">
          <div class="st active"><span>1</span><em>Apply</em></div>
          <div class="st-line"></div>
          <div class="st active"><span>2</span><em>Interview</em></div>
          <div class="st-line"></div>
          <div class="st"><span>3</span><em>Accept</em></div>
          <div class="st-line"></div>
          <div class="st"><span>4</span><em>Arrive</em></div>
        </div>
        <div class="sub-label">Kanban columns</div>
        <div class="kanban">
          <div class="kb-col"><h4>Week 1</h4><div class="kb-card">Scope & research</div><div class="kb-card">First prototype</div><div class="kb-card">Operator review</div></div>
          <div class="kb-col"><h4>Week 2</h4><div class="kb-card">Build v2</div><div class="kb-card">Field test</div><div class="kb-card">Final demo</div></div>
