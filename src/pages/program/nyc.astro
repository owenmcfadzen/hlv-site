---
import Base from '../../layouts/Base.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import Quote from '../../components/Quote.astro';
---

<Base title="New York City" navVariant="dark" navActive="program">

  <section class="prog-hero">
    <div class="prog-hero-bg"></div>
    <div class="prog-hero-placeholder"><span>NYC hero — street-level Manhattan, evening light</span></div>
    <div class="prog-hero-content">
      <div class="prog-hero-label">New York City · Summer 2026</div>
      <div class="hl-stack">
        <span class="hl-block" style="background: var(--violet);">Build something real</span>
        <span class="hl-block" style="background: var(--pop); color: var(--navy); margin-left: 24px;">in the city that</span>
        <span class="hl-block" style="background: var(--navy); margin-left: 48px;">never stops building</span>
      </div>
      <p class="prog-hero-sub"><strong>Two weeks. Three tracks. One cohort.</strong> Work alongside practitioners in product, business, and go-to-market — in a city where every block teaches you something about how things get made.</p>
      <div class="prog-hero-meta">
        <div class="meta-item"><span class="v">June 27</span><span class="l">Start Date</span></div>
        <div class="meta-item"><span class="v">July 11</span><span class="l">End Date</span></div>
        <div class="meta-item"><span class="v">24</span><span class="l">Students</span></div>
        <div class="meta-item"><span class="v">3</span><span class="l">Tracks</span></div>
      </div>
    </div>
  </section>

  <div class="a5c-inline"><div style="flex:6;background:var(--violet);"></div><div style="flex:5;background:var(--blue);"></div><div style="flex:4;background:var(--coral);"></div><div style="flex:3;background:var(--pop);"></div><div style="flex:2;background:var(--green);"></div><div style="flex:2;background:var(--navy);"></div></div>

  <section class="intro-split">
    <div class="intro-text-col">
      <h2>This Isn't a Summer Class</h2>
      <p><span class="lead">Hudson Lab is a working studio.</span> You won't sit in lectures. You'll build real projects — prototypes, business cases, campaign strategies — with guidance from people who've actually shipped things.</p>
      <p>New York is the context, not the backdrop. You'll use the city as a research lab: interviewing strangers, testing ideas in real markets, learning from a place that doesn't slow down for anyone.</p>
    </div>
    <div class="intro-photo-col">
      <div class="edge" style="background: var(--violet);"></div>
      <span class="photo-placeholder">Students working in studio space</span>
    </div>
  </section>

  <div class="photo-full"><span class="photo-placeholder">Full-width: NYC neighborhood street, daytime</span></div>

  <section class="your-day"><div class="mw">
    <div class="day-header"><SectionHeader title="Your Day" subtitle="Structured around doing. Foundation mornings, track afternoons, city evenings." color="coral" /></div>
    <div class="day-row"><div class="day-time"><span class="t">9:00</span></div><div class="day-name"><h3>Morning Assembly</h3></div><div class="day-desc"><p>Whole cohort. Check-ins, day context, city logistics.</p></div></div>
    <div class="day-featured"><div class="day-time"><span class="t">9:30</span></div><div class="day-feat-content"><h3>Foundation Session</h3><p>Cross-track. The shared language — user research, storytelling, financial reasoning, systems thinking.</p><span class="day-tag" style="background:rgba(123,79,219,0.08);color:var(--violet);">All Tracks · 90 min</span></div></div>
    <div class="day-row"><div class="day-time"><span class="t">11:00</span></div><div class="day-name"><h3>Break</h3></div><div class="day-desc"><p>Coffee. Talk to someone from a different track.</p></div></div>
    <div class="day-featured"><div class="day-time"><span class="t">11:15</span></div><div class="day-feat-content"><h3>Track Studio</h3><p>Your track, your tools, your project. Facilitators coach, not lecture.</p><span class="day-tag" style="background:rgba(228,108,65,0.08);color:var(--coral);">Track-Specific · 105 min</span></div></div>
    <div class="day-row"><div class="day-time"><span class="t">13:00</span></div><div class="day-name"><h3>Lunch</h3></div><div class="day-desc"><p>Together. City-sourced. The best conversations happen here.</p></div></div>
    <div class="day-featured"><div class="day-time"><span class="t">14:00</span></div><div class="day-feat-content"><h3>Build Sprint</h3><p>Deep work. This is where artifacts get made. Facilitators available, not hovering.</p><span class="day-tag" style="background:rgba(228,108,65,0.08);color:var(--coral);">Track-Specific · 120 min</span></div></div>
    <div class="day-row"><div class="day-time"><span class="t">16:00</span></div><div class="day-name"><h3>Crit & Share</h3></div><div class="day-desc"><p>Cross-track. Show your work, get honest feedback.</p></div></div>
    <div class="day-row last"><div class="day-time"><span class="t">17:00</span></div><div class="day-name"><h3>Reflection</h3></div><div class="day-desc"><p>Quick journaling. What's unresolved? Then done.</p></div></div>
  </div></section>

  <section class="tracks-dark"><div class="mw">
    <SectionHeader title="Three Tracks" subtitle="Pick the one that matches how you think." color="blue" />
    <div class="asc-grid">
      <div class="asc-card" style="background:var(--coral);"><div class="ghost">01</div><span class="label-sm t-label">Product</span><h3>Design & Build</h3><p><span class="lead">Turn problems into prototypes.</span> User research, IA, interaction design. Ship something testable by week two.</p></div>
      <div class="asc-card" style="background:var(--green);"><div class="ghost">02</div><span class="label-sm t-label">Business</span><h3>Model & Validate</h3><p><span class="lead">Make the numbers work.</span> Revenue models, unit economics, competitive analysis.</p></div>
      <div class="asc-card" style="background:var(--blue);"><div class="ghost">03</div><span class="label-sm t-label">Go-To-Market</span><h3>Launch & Grow</h3><p><span class="lead">Get it in front of people.</span> Positioning, channels, campaign execution.</p></div>
    </div>
  </div></section>

  <Quote text="I came in thinking I wanted to do product. By day four, I realized I was a business person who happened to like design." attribution="NYC 2025" />

  <section class="fac-section"><div class="mw">
    <SectionHeader title="Your NYC Facilitators" color="pop" />
    <div class="fac-row"><div class="fac-photo-col"><div class="fac-photo-box"><div class="c-dot" style="background:var(--coral);"></div><span class="photo-placeholder" style="color:var(--text-light);">Photo</span></div></div><div class="fac-info-col"><span class="label-sm f-track" style="color:var(--coral);">Product Track</span><h3>Stacey Seltzer</h3><p><span class="lead">A decade of shipping product at scale.</span> Stacey designed HLV's Product track — exercises built from real product decisions.</p></div></div>
    <div class="fac-row"><div class="fac-photo-col"><div class="fac-photo-box"><div class="c-dot" style="background:var(--green);"></div><span class="photo-placeholder" style="color:var(--text-light);">Photo</span></div></div><div class="fac-info-col"><span class="label-sm f-track" style="color:var(--green);">Business Track</span><h3>Takeshi</h3><p><span class="lead">Business strategy rooted in real operations.</span> He asks "but do the unit economics work?" until you can answer with confidence.</p></div></div>
    <div class="fac-row last"><div class="fac-photo-col"><div class="fac-photo-box"><div class="c-dot" style="background:var(--blue);"></div><span class="photo-placeholder" style="color:var(--text-light);">Photo</span></div></div><div class="fac-info-col"><span class="label-sm f-track" style="color:var(--blue);">Go-To-Market Track</span><h3>Luke</h3><p><span class="lead">Growth and go-to-market from the ground up.</span> Bias toward measurement — if you can't track it, you can't improve it.</p></div></div>
  </div></section>

  <section class="logistics-section"><div class="mw">
    <SectionHeader title="Logistics" color="navy" />
    <div class="log-grid bordered-grid">
      <div class="log-item"><div class="log-l label-xs">Dates</div><div class="log-v">June 27 – July 11</div><div class="log-d">Two weeks, Monday–Friday</div></div>
      <div class="log-item"><div class="log-l label-xs">Hours</div><div class="log-v">9:00 – 17:00</div><div class="log-d">Evenings free</div></div>
      <div class="log-item"><div class="log-l label-xs">Location</div><div class="log-v">Manhattan</div><div class="log-d">Studio workspace TBA</div></div>
      <div class="log-item"><div class="log-l label-xs">Cohort</div><div class="log-v">24 Students</div><div class="log-d">8 per track</div></div>
      <div class="log-item"><div class="log-l label-xs">Housing</div><div class="log-v">Available</div><div class="log-d">Supervised, near studio</div></div>
      <div class="log-item"><div class="log-l label-xs">Includes</div><div class="log-v">Lunch Daily</div><div class="log-d">All materials, city activities</div></div>
    </div>
  </div></section>

  <section class="prog-cta">
    <div class="hl-stack" style="align-items:center;"><span class="hl-block" style="background:var(--violet);">Two weeks in New York.</span><span class="hl-block" style="background:var(--pop);color:var(--navy);">One real project.</span></div>
    <p class="cta-sub">Rolling admissions. Apply in 15 minutes.</p>
    <a href="/admissions" class="btn-violet">Apply for NYC →</a>
  </section>

</Base>

<style>
  .prog-hero{position:relative;min-height:100vh;background:var(--dark);display:flex;flex-direction:column;justify-content:flex-end;padding:0 0 80px;overflow:hidden;}
  .prog-hero-bg{position:absolute;inset:0;background:linear-gradient(135deg,#1a0f2e 0%,#18181b 40%,#1a1a2e 100%);}
  .prog-hero-placeholder{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;opacity:0.15;}
  .prog-hero-placeholder span{border:1px solid rgba(255,255,255,0.3);padding:24px 40px;font-family:'Barlow Semi Condensed',sans-serif;font-size:13px;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;color:white;}
  .prog-hero-content{position:relative;z-index:2;padding:0 80px;max-width:1200px;}
  .prog-hero-label{font-family:'Barlow Semi Condensed',sans-serif;font-size:13px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--violet);margin-bottom:24px;}
  .prog-hero-sub{font-size:18px;color:rgba(255,255,255,0.55);max-width:520px;line-height:1.6;margin-bottom:40px;}
  .prog-hero-sub strong{color:rgba(255,255,255,0.85);font-weight:500;}
  .prog-hero-meta{display:flex;gap:48px;align-items:baseline;}
  .meta-item{display:flex;flex-direction:column;}
  .meta-item .v{font-size:28px;font-weight:600;color:white;line-height:1.1;}
  .meta-item .l{font-family:'Barlow Semi Condensed',sans-serif;font-size:11px;font-weight:500;letter-spacing:0.06em;text-transform:uppercase;color:rgba(255,255,255,0.35);margin-top:4px;}
  .a5c-inline{display:flex;height:5px;width:100%;}
  .intro-split{display:grid;grid-template-columns:1fr 1fr;min-height:560px;}
  .intro-text-col{padding:100px 80px;display:flex;flex-direction:column;justify-content:center;max-width:640px;margin-left:auto;}
  .intro-text-col h2{font-size:34px;font-weight:600;line-height:1.18;color:var(--navy);margin-bottom:20px;}
  .intro-text-col p{font-size:17px;line-height:1.65;color:var(--text-mid);margin-bottom:16px;}
  .intro-photo-col{position:relative;display:flex;align-items:center;justify-content:center;background:var(--bg-subtle);}
  .intro-photo-col .edge{position:absolute;left:0;top:0;bottom:0;width:6px;}
  .photo-full{width:100%;height:520px;background:var(--bg-subtle);display:flex;align-items:center;justify-content:center;}
  .photo-full span{border:1px solid var(--border);padding:16px 32px;}
  .your-day{padding:120px 0;}
  .day-header{margin-bottom:64px;}
  .day-row{display:grid;grid-template-columns:160px 1fr 1fr;border-top:1px solid var(--border);}
  .day-row.last{border-bottom:1px solid var(--border);}
  .day-time{padding:32px 32px 32px 0;display:flex;flex-direction:column;align-items:flex-end;text-align:right;}
  .day-time .t{font-size:15px;font-weight:600;color:var(--navy);}
  .day-name{padding:32px 24px;border-left:1px solid var(--border);}
  .day-name h3{font-size:18px;font-weight:600;color:var(--navy);}
  .day-desc{padding:32px 0 32px 24px;border-left:1px solid var(--border);}
  .day-desc p{font-size:15px;line-height:1.55;color:var(--text-mid);}
  .day-featured{display:grid;grid-template-columns:160px 1fr;border-top:1px solid var(--border);}
  .day-featured .day-time{padding:48px 32px 48px 0;}
  .day-feat-content{border-left:1px solid var(--border);padding:48px 0 48px 24px;}
  .day-feat-content h3{font-size:22px;font-weight:600;color:var(--navy);margin-bottom:8px;}
  .day-feat-content p{font-size:16px;line-height:1.6;color:var(--text-mid);max-width:520px;margin-bottom:16px;}
  .day-tag{display:inline-block;padding:3px 10px;font-family:'Barlow Semi Condensed',sans-serif;font-size:11px;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;}
  .tracks-dark{background:var(--dark);padding:120px 0 0;}
  .tracks-dark :global(.section-header h2){color:white;}
  .tracks-dark :global(.section-header .sub){color:rgba(255,255,255,0.5);}
  .asc-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;padding:64px 0 120px;align-items:end;}
  .asc-card{display:flex;flex-direction:column;padding:48px 36px;border-radius:2px;}
  .asc-card:nth-child(1){min-height:360px;}
  .asc-card:nth-child(2){min-height:400px;}
  .asc-card:nth-child(3){min-height:440px;}
  .ghost{font-size:88px;font-weight:600;line-height:1;opacity:0.12;color:white;margin-bottom:auto;}
  .t-label{color:rgba(255,255,255,0.6);margin-bottom:8px;display:block;}
  .asc-card h3{font-size:24px;font-weight:600;color:white;margin-bottom:8px;}
  .asc-card p{font-size:15px;line-height:1.55;color:rgba(255,255,255,0.6);}
  .asc-card p :global(.lead){font-weight:500;color:rgba(255,255,255,0.85);}
  .fac-section{padding:120px 0;}
  .fac-section :global(.section-header){margin-bottom:64px;}
  .fac-row{display:grid;grid-template-columns:280px 1fr;border-top:1px solid var(--border);}
  .fac-row.last{border-bottom:1px solid var(--border);}
  .fac-photo-col{padding:40px 32px 40px 0;}
  .fac-photo-box{width:100%;aspect-ratio:1;background:var(--bg-subtle);border-radius:2px;display:flex;align-items:center;justify-content:center;position:relative;}
  .c-dot{position:absolute;top:12px;left:12px;width:10px;height:10px;}
  .fac-info-col{padding:48px 0 48px 40px;border-left:1px solid var(--border);display:flex;flex-direction:column;justify-content:center;}
  .f-track{margin-bottom:6px;display:block;}
  .fac-info-col h3{font-size:24px;font-weight:600;color:var(--navy);margin-bottom:10px;}
  .fac-info-col p{font-size:16px;line-height:1.6;color:var(--text-mid);max-width:480px;}
  .logistics-section{padding:100px 0;}
  .logistics-section :global(.section-header){margin-bottom:48px;}
  .log-grid{display:grid;grid-template-columns:repeat(3,1fr);}
  .log-item{padding:36px 32px;}
  .log-l{margin-bottom:8px;color:var(--text-light);}
  .log-v{font-size:18px;font-weight:600;color:var(--navy);margin-bottom:4px;}
  .log-d{font-size:14px;color:var(--text-mid);}
  .prog-cta{background:var(--dark);padding:100px 80px;text-align:center;display:flex;flex-direction:column;align-items:center;}
  .prog-cta .hl-stack{margin-bottom:24px;}
  .cta-sub{font-size:17px;color:rgba(255,255,255,0.45);margin-bottom:36px;}
</style>
