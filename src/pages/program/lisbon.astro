---
import Base from '../../layouts/Base.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import Quote from '../../components/Quote.astro';
---

<Base title="Lisbon" navVariant="dark" navActive="program">
  <section class="prog-hero"><div class="prog-hero-bg" style="background:linear-gradient(135deg,#0f1a3a 0%,#18181b 50%,#0d2240 100%);"></div><div class="prog-hero-placeholder"><span>Lisbon — tram, Alfama rooftops, golden light</span></div><div class="prog-hero-content">
    <div class="prog-hero-label">Lisbon, Portugal · Summer 2026</div>
    <div class="hl-stack">
      <span class="hl-block" style="background:var(--blue);">Innovation at a</span>
      <span class="hl-block" style="background:var(--pop);color:var(--navy);margin-left:24px;">human scale</span>
    </div>
    <p class="prog-hero-sub"><strong>Two weeks. Real challenges. Europe's startup capital.</strong> Partner with José de Mello and Sonae to tackle real business problems — from AI in education to the future of retail — in a city where founders are accessible and the cost of experimentation is low.</p>
    <div class="prog-hero-meta"><div class="meta-item"><span class="v">July 13</span><span class="l">Start Date</span></div><div class="meta-item"><span class="v">July 25</span><span class="l">End Date</span></div><div class="meta-item"><span class="v">20</span><span class="l">Students</span></div><div class="meta-item"><span class="v">3</span><span class="l">Tracks</span></div></div>
  </div></section>
  <div class="a5c-inline"><div style="flex:6;background:var(--violet);"></div><div style="flex:5;background:var(--blue);"></div><div style="flex:4;background:var(--coral);"></div><div style="flex:3;background:var(--pop);"></div><div style="flex:2;background:var(--green);"></div><div style="flex:2;background:var(--navy);"></div></div>

  <section class="intro-split"><div class="intro-text-col">
    <h2>Two Challenges. One City.</h2>
    <p><span class="lead">Lisbon's program offers two distinct innovation challenges.</span> Work with José de Mello — a legacy Portuguese company — to explore whether AI can solve Portugal's education crisis. Or partner with Sonae, Portugal's largest conglomerate, to reimagine the future of retail.</p>
    <p>Both challenges are real. Both have executives waiting for your solutions. You'll present to the people who make the decisions.</p>
  </div><div class="intro-photo-col"><div class="edge" style="background:var(--blue);"></div><span class="photo-placeholder">Students working in Lisbon</span></div></section>

  <div class="photo-full"><span class="photo-placeholder">Full-width: Lisbon streets, tiled facades, golden hour</span></div>

  <!-- YOUR TWO WEEKS -->
  <section class="weeks-section"><div class="mw">
    <SectionHeader title="Your Two Weeks" subtitle="Week one builds the foundation. Week two ships the work." color="blue" />
    <div class="weeks-grid">
      <div class="week-card">
        <div class="week-num" style="color:var(--blue);">Week 1</div>
        <h3>Research & Define</h3>
        <div class="week-days">
          <div class="wd"><strong>Mon–Tue</strong><span>Team formation, partner briefing, foundation sessions. Meet your challenge sponsor — José de Mello or Sonae — and understand the problem space.</span></div>
          <div class="wd"><strong>Wed–Thu</strong><span>User research in the field. Get out of the studio and into Lisbon — interviews, observations, market visits. The city is your research lab.</span></div>
          <div class="wd"><strong>Fri</strong><span>Problem definition. Synthesize research. Present your framing to the cohort for cross-track feedback.</span></div>
        </div>
      </div>
      <div class="week-card">
        <div class="week-num" style="color:var(--coral);">Week 2</div>
        <h3>Build & Present</h3>
        <div class="week-days">
          <div class="wd"><strong>Mon–Tue</strong><span>Prototyping, modeling, campaign building. Each track produces its deliverable — solutions to real challenges these companies face.</span></div>
          <div class="wd"><strong>Wed–Thu</strong><span>Iteration and testing. Refine based on feedback. Rehearse presentations. Polish to a professional standard.</span></div>
          <div class="wd"><strong>Fri</strong><span>Final presentations to José de Mello and Sonae executives. The people in the room make real decisions based on what you show them.</span></div>
        </div>
      </div>
    </div>
  </div></section>

  <!-- PARTNER -->
  <section class="partner-section"><div class="mw">
    <div class="partner-layout">
      <div class="partner-text">
        <SectionHeader title="Your Challenge Partners" color="blue" />
        <p><span class="lead">Two challenges, two of Portugal's most important companies.</span> Work with José de Mello — a legacy company committed to public good — on whether AI can solve Portugal's education crisis. Or partner with Sonae, Portugal's largest conglomerate, to reimagine the future of retail.</p>
        <p>Both challenges are active questions these companies are working to answer. Your team's thinking becomes part of that conversation.</p>
      </div>
      <div class="partner-photo">
        <span class="photo-placeholder">Lisbon innovation hub / Unicorn Factory</span>
      </div>
    </div>
  </div></section>

  <!-- TRAVEL & LOCAL -->
  <section class="travel-section"><div class="mw">
    <SectionHeader title="Getting There" color="green" />
    <div class="travel-grid bordered-grid">
      <div class="travel-item"><div class="t-icon"><svg viewBox="0 0 24 24" stroke="var(--navy)" width="20" height="20"><path d="M12 3 L20 7.5 L20 16.5 L12 21 L4 16.5 L4 7.5 Z"/></svg></div><h3>Travel Together</h3><p>International students meet an HLV chaperone and travel together to Lisbon. You won't navigate this alone.</p></div>
      <div class="travel-item"><div class="t-icon"><svg viewBox="0 0 24 24" stroke="var(--navy)" width="20" height="20"><rect x="3" y="6" width="18" height="14"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div><h3>Housing in Central Lisbon</h3><p>Supervised accommodation through vetted local partners. Walking distance to the program venue. On-site support staff. Day-student option available.</p></div>
      <div class="travel-item"><div class="t-icon"><svg viewBox="0 0 24 24" stroke="var(--navy)" width="20" height="20"><circle cx="12" cy="12" r="9"/><line x1="12" y1="7" x2="12" y2="12"/><line x1="12" y1="12" x2="16" y2="14"/></svg></div><h3>Your Evenings</h3><p>Lisbon is yours after hours. Cobblestone streets, pastéis de nata, incredible food scene. Curated guides, optional group dinners, always supervised when organized by HLV.</p></div>
    </div>
  </div></section>

  <Quote text="Lisbon taught me that the best ideas don't come from sitting in a room — they come from walking a city and asking questions." attribution="Lisbon 2025" />

  <section class="logistics-section"><div class="mw">
    <SectionHeader title="Logistics" color="navy" />
    <div class="log-grid bordered-grid">
      <div class="log-item"><div class="log-l label-xs">Dates</div><div class="log-v">July 13 – July 25</div><div class="log-d">Two weeks, Monday–Friday</div></div>
      <div class="log-item"><div class="log-l label-xs">Hours</div><div class="log-v">9:00 – 17:00</div><div class="log-d">Evenings free</div></div>
      <div class="log-item"><div class="log-l label-xs">Location</div><div class="log-v">Lisbon</div><div class="log-d">Unicorn Factory Lisboa</div></div>
      <div class="log-item"><div class="log-l label-xs">Cohort</div><div class="log-v">20 Students</div><div class="log-d">International mix</div></div>
      <div class="log-item"><div class="log-l label-xs">Housing</div><div class="log-v">Available</div><div class="log-d">Supervised, central Lisbon</div></div>
      <div class="log-item"><div class="log-l label-xs">Partners</div><div class="log-v">José de Mello · Sonae</div><div class="log-d">Real corporate challenges</div></div>
    </div>
  </div></section>

  <section class="prog-cta">
    <div class="hl-stack" style="align-items:center;"><span class="hl-block" style="background:var(--blue);">Two weeks in Lisbon.</span><span class="hl-block" style="background:var(--pop);color:var(--navy);">Real problems. Real executives.</span></div>
    <p class="cta-sub">Rolling admissions. Apply in 15 minutes.</p>
    <a href="/admissions" class="btn-violet">Apply for Lisbon →</a>
  </section>
</Base>

<style>

  @media (max-width: 768px) {
    .prog-hero { min-height: 90vh; padding-bottom: 40px; }
    .prog-hero-content { padding: 0 24px; }
    .prog-hero-meta { flex-wrap: wrap; gap: 24px; }
    .meta-item .v { font-size: 22px; }
    .intro-split { grid-template-columns: 1fr; }
    .intro-text-col { padding: 60px 24px; max-width: 100%; margin: 0; }
    .intro-text-col h2 { font-size: 28px; }
    .intro-photo-col { height: 300px; }
    .photo-full { height: 280px; }
    .logistics-section .mw { padding: 0 24px; }
    .log-grid { grid-template-columns: 1fr 1fr; }
    .prog-cta { padding: 60px 24px; }
  }

</style>


