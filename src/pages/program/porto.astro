---
import Base from '../../layouts/Base.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import Quote from '../../components/Quote.astro';
---

<Base title="Porto" navVariant="dark" navActive="program">
  <section class="prog-hero"><div class="prog-hero-bg" style="background:linear-gradient(135deg,#2a150f 0%,#18181b 50%,#1a1210 100%);"></div><div class="prog-hero-placeholder"><span>Porto — Ribeira district, Douro river, tile facades</span></div><div class="prog-hero-content">
    <div class="prog-hero-label">Porto, Portugal · Summer 2026</div>
    <div class="hl-stack">
      <span class="hl-block" style="background:var(--coral);">Craft meets</span>
      <span class="hl-block" style="background:var(--pop);color:var(--navy);margin-left:24px;">entrepreneurship</span>
    </div>
    <p class="prog-hero-sub"><strong>Two weeks. Real challenges. Europe's startup capital.</strong> Build in a city that takes making things seriously — from port wine to ceramics to software. Porto's entrepreneurial culture is grounded in craft, precision, and doing things right.</p>
    <div class="prog-hero-meta"><div class="meta-item"><span class="v">July 13</span><span class="l">Start Date</span></div><div class="meta-item"><span class="v">July 25</span><span class="l">End Date</span></div><div class="meta-item"><span class="v">16</span><span class="l">Students</span></div><div class="meta-item"><span class="v">2</span><span class="l">Tracks</span></div></div>
  </div></section>
  <div class="a5c-inline"><div style="flex:6;background:var(--violet);"></div><div style="flex:5;background:var(--coral);"></div><div style="flex:4;background:var(--coral);"></div><div style="flex:3;background:var(--pop);"></div><div style="flex:2;background:var(--green);"></div><div style="flex:2;background:var(--navy);"></div></div>

  <section class="intro-split"><div class="intro-text-col">
    <h2>Where Making Things Matters</h2>
    <p><span class="lead">Porto's program offers two distinct innovation challenges.</span> Work with José de Mello — a legacy Portuguese company — to explore whether AI can solve Portugal's education crisis. Or partner with Sonae, Portugal's largest conglomerate, to reimagine the future of retail.</p>
    <p>The city's culture of craftsmanship seeps into everything. When you present your work here, "good enough" doesn't fly.</p>
  </div><div class="intro-photo-col"><div class="edge" style="background:var(--coral);"></div><span class="photo-placeholder">Students in Porto workspace</span></div></section>

  <div class="photo-full"><span class="photo-placeholder">Full-width: Porto riverside, bridges, afternoon light</span></div>

  <!-- YOUR TWO WEEKS -->
  <section class="weeks-section"><div class="mw">
    <SectionHeader title="Your Two Weeks" subtitle="Week one builds the foundation. Week two ships the work." color="coral" />
    <div class="weeks-grid">
      <div class="week-card"><div class="week-num" style="color:var(--coral);">Week 1</div><h3>Research & Define</h3><div class="week-days">
        <div class="wd"><strong>Mon-Tue</strong><span>Team formation, foundation sessions. Understand your challenge and the Porto context — a city where craft and quality drive everything.</span></div>
        <div class="wd"><strong>Wed-Thu</strong><span>Research in the field. Porto rewards going deep — interviews, observations, understanding the local market and culture.</span></div>
        <div class="wd"><strong>Fri</strong><span>Problem definition. Synthesize research. Present your framing for cross-track feedback.</span></div>
      </div></div>
      <div class="week-card"><div class="week-num" style="color:var(--green);">Week 2</div><h3>Build & Present</h3><div class="week-days">
        <div class="wd"><strong>Mon-Tue</strong><span>Build your deliverables. Porto's smaller cohort means more focused feedback and deeper work.</span></div>
        <div class="wd"><strong>Wed-Thu</strong><span>Iteration and testing. Polish to a professional standard. Rehearse presentations.</span></div>
        <div class="wd"><strong>Fri</strong><span>Final presentations. In Porto, "good enough" doesn't fly — the city's craft culture seeps into the standard.</span></div>
      </div></div>
    </div>
  </div></section>
  <section class="travel-section"><div class="mw">
    <SectionHeader title="Getting There" color="green" />
    <div class="travel-grid bordered-grid">
      <div class="travel-item"><div class="t-icon"><svg viewBox="0 0 24 24" stroke="var(--navy)" width="20" height="20"><path d="M12 3 L20 7.5 L20 16.5 L12 21 L4 16.5 L4 7.5 Z"/></svg></div><h3>Travel Together</h3><p>International students meet an HLV chaperone and travel together to Porto.</p></div>
      <div class="travel-item"><div class="t-icon"><svg viewBox="0 0 24 24" stroke="var(--navy)" width="20" height="20"><rect x="3" y="6" width="18" height="14"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div><h3>Housing in Central Porto</h3><p>Supervised accommodation near the Douro. On-site support staff. Day-student option available.</p></div>
      <div class="travel-item"><div class="t-icon"><svg viewBox="0 0 24 24" stroke="var(--navy)" width="20" height="20"><circle cx="12" cy="12" r="9"/><line x1="12" y1="7" x2="12" y2="12"/><line x1="12" y1="12" x2="16" y2="14"/></svg></div><h3>Your Evenings</h3><p>Porto's food scene is underrated and unforgettable. Curated guides, optional group dinners, riverside walks.</p></div>
    </div>
  </div></section>

  <Quote text="Porto slowed me down in the best way. I stopped trying to move fast and started trying to move right." attribution="Porto 2025" />

  <section class="logistics-section"><div class="mw">
    <SectionHeader title="Logistics" color="navy" />
    <div class="log-grid bordered-grid">
      <div class="log-item"><div class="log-l label-xs">Dates</div><div class="log-v">July 13 – July 25</div><div class="log-d">Two weeks, Monday–Friday</div></div>
      <div class="log-item"><div class="log-l label-xs">Hours</div><div class="log-v">9:00 – 17:00</div><div class="log-d">Evenings free</div></div>
      <div class="log-item"><div class="log-l label-xs">Location</div><div class="log-v">Porto</div><div class="log-d">Unicorn Factory Lisboa</div></div>
      <div class="log-item"><div class="log-l label-xs">Cohort</div><div class="log-v">20 Students</div><div class="log-d">International mix</div></div>
      <div class="log-item"><div class="log-l label-xs">Housing</div><div class="log-v">Available</div><div class="log-d">Supervised, central Porto</div></div>
      <div class="log-item"><div class="log-l label-xs">Partners</div><div class="log-v">TBA</div><div class="log-d">Details coming soon</div></div>
    </div>
  </div></section>

  <section class="prog-cta">
    <div class="hl-stack" style="align-items:center;"><span class="hl-block" style="background:var(--coral);">Two weeks in Porto.</span><span class="hl-block" style="background:var(--pop);color:var(--navy);">Craft it right.</span></div>
    <p class="cta-sub">Rolling admissions. Apply in 15 minutes.</p>
    <a href="/admissions" class="btn-violet">Apply for Porto →</a>
  </section>
</Base>

<style>
  .prog-hero{position:relative;min-height:100vh;background:var(--dark);display:flex;flex-direction:column;justify-content:flex-end;padding:0 0 80px;overflow:hidden;}.prog-hero-bg{position:absolute;inset:0;}.prog-hero-placeholder{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;opacity:0.15;}.prog-hero-placeholder span{border:1px solid rgba(255,255,255,0.3);padding:24px 40px;font-family:'Barlow Semi Condensed',sans-serif;font-size:13px;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;color:white;}.prog-hero-content{position:relative;z-index:2;padding:0 80px;max-width:1200px;}.prog-hero-label{font-family:'Barlow Semi Condensed',sans-serif;font-size:13px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--coral);margin-bottom:24px;}.prog-hero-sub{font-size:18px;color:rgba(255,255,255,0.55);max-width:520px;line-height:1.6;margin-bottom:40px;}.prog-hero-sub strong{color:rgba(255,255,255,0.85);font-weight:500;}.prog-hero-meta{display:flex;gap:48px;align-items:baseline;}.meta-item{display:flex;flex-direction:column;}.meta-item .v{font-size:28px;font-weight:600;color:white;line-height:1.1;}.meta-item .l{font-family:'Barlow Semi Condensed',sans-serif;font-size:11px;font-weight:500;letter-spacing:0.06em;text-transform:uppercase;color:rgba(255,255,255,0.35);margin-top:4px;}.a5c-inline{display:flex;height:5px;width:100%;}.intro-split{display:grid;grid-template-columns:1fr 1fr;min-height:560px;}.intro-text-col{padding:100px 80px;display:flex;flex-direction:column;justify-content:center;max-width:640px;margin-left:auto;}.intro-text-col h2{font-size:34px;font-weight:600;line-height:1.18;color:var(--navy);margin-bottom:20px;}.intro-text-col p{font-size:17px;line-height:1.65;color:var(--text-mid);margin-bottom:16px;}.intro-photo-col{position:relative;display:flex;align-items:center;justify-content:center;background:var(--bg-subtle);}.intro-photo-col .edge{position:absolute;left:0;top:0;bottom:0;width:6px;}.photo-full{width:100%;height:520px;background:var(--bg-subtle);display:flex;align-items:center;justify-content:center;}.photo-full span{border:1px solid var(--border);padding:16px 32px;}.your-day{padding:120px 0;}.day-header{margin-bottom:64px;}.day-row{display:grid;grid-template-columns:160px 1fr 1fr;border-top:1px solid var(--border);}.day-row.last{border-bottom:1px solid var(--border);}.day-time{padding:32px 32px 32px 0;display:flex;flex-direction:column;align-items:flex-end;text-align:right;}.day-time .t{font-size:15px;font-weight:600;color:var(--navy);}.day-name{padding:32px 24px;border-left:1px solid var(--border);}.day-name h3{font-size:18px;font-weight:600;color:var(--navy);}.day-desc{padding:32px 0 32px 24px;border-left:1px solid var(--border);}.day-desc p{font-size:15px;line-height:1.55;color:var(--text-mid);}.day-featured{display:grid;grid-template-columns:160px 1fr;border-top:1px solid var(--border);}.day-featured .day-time{padding:48px 32px 48px 0;}.day-feat-content{border-left:1px solid var(--border);padding:48px 0 48px 24px;}.day-feat-content h3{font-size:22px;font-weight:600;color:var(--navy);margin-bottom:8px;}.day-feat-content p{font-size:16px;line-height:1.6;color:var(--text-mid);max-width:520px;margin-bottom:16px;}.day-tag{display:inline-block;padding:3px 10px;font-family:'Barlow Semi Condensed',sans-serif;font-size:11px;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;}.weeks-section{padding:120px 0;}.weeks-section :global(.section-header){margin-bottom:48px;}.weeks-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px;}.week-card{border:1px solid var(--border);border-radius:2px;padding:40px 36px;}.week-num{font-size:14px;font-weight:600;font-family:'Barlow Semi Condensed',sans-serif;letter-spacing:0.06em;text-transform:uppercase;margin-bottom:8px;}.week-card h3{font-size:24px;font-weight:600;color:var(--navy);margin-bottom:24px;}.week-days{display:flex;flex-direction:column;}.wd{padding:16px 0;border-top:1px solid var(--border);}.wd strong{display:block;font-size:14px;font-weight:600;color:var(--navy);margin-bottom:4px;}.wd span{font-size:14px;line-height:1.55;color:var(--text-mid);}.partner-section{padding:0 0 100px;}.partner-section :global(.section-header){margin-bottom:20px;}.partner-layout{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;}.partner-text p{font-size:16px;line-height:1.65;color:var(--text-mid);margin-bottom:16px;margin-top:20px;}.partner-photo{aspect-ratio:4/3;background:var(--bg-subtle);border-radius:2px;display:flex;align-items:center;justify-content:center;}.travel-section{padding:0 0 100px;}.travel-section :global(.section-header){margin-bottom:36px;}.travel-grid{display:grid;grid-template-columns:repeat(3,1fr);}.travel-item{padding:32px;}.t-icon{width:40px;height:40px;display:flex;align-items:center;justify-content:center;margin-bottom:16px;}.t-icon svg{stroke-width:1.5;stroke-linecap:square;stroke-linejoin:miter;fill:none;}.travel-item h3{font-size:17px;font-weight:600;color:var(--navy);margin-bottom:8px;}.travel-item p{font-size:14px;line-height:1.55;color:var(--text-mid);}.logistics-section{padding:100px 0;}.logistics-section :global(.section-header){margin-bottom:48px;}.log-grid{display:grid;grid-template-columns:repeat(3,1fr);}.log-item{padding:36px 32px;}.log-l{margin-bottom:8px;color:var(--text-light);}.log-v{font-size:18px;font-weight:600;color:var(--navy);margin-bottom:4px;}.log-d{font-size:14px;color:var(--text-mid);}.prog-cta{background:var(--dark);padding:100px 80px;text-align:center;display:flex;flex-direction:column;align-items:center;}.prog-cta .hl-stack{margin-bottom:24px;}.cta-sub{font-size:17px;color:rgba(255,255,255,0.45);margin-bottom:36px;}

  @media (max-width: 768px) {
    .prog-hero { min-height: 90vh; padding-bottom: 40px; }
    .prog-hero-content { padding: 0 24px; }
    .prog-hero-meta { flex-wrap: wrap; gap: 24px; }
    .meta-item .v { font-size: 22px; }
    .intro-split { grid-template-columns: 1fr; }
    .intro-text-col { padding: 60px 24px; max-width: 100%; margin: 0; }
    .intro-text-col h2 { font-size: 28px; }
    .intro-photo-col { height: 300px; }
    .photo-full { height: 280px; }
    .your-day { padding: 80px 0; }
    .your-day .mw { padding: 0 24px; }
    .weeks-grid { grid-template-columns: 1fr; }
    .partner-layout { grid-template-columns: 1fr; }
    .travel-grid { grid-template-columns: 1fr; }
    .weeks-section .mw { padding: 0 24px; }
    .partner-section .mw { padding: 0 24px; }
    .travel-section .mw { padding: 0 24px; }
    .partner-photo { height: 240px; }
    .logistics-section .mw { padding: 0 24px; }
    .log-grid { grid-template-columns: 1fr 1fr; }
    .prog-cta { padding: 60px 24px; }
  }

</style>


